---
import { SITE_IDENTITY } from '../data/site-identity';

interface Props {
  variant?: 'home' | 'inner';
}

const { variant = 'inner' } = Astro.props;
const phoneLink = SITE_IDENTITY.phoneTel;
---

<div
  class:list={[
    'promotion-banner',
    variant === 'home' ? 'promotion-banner--home' : 'promotion-banner--inner',
  ]}
  role="region"
  aria-label="Eripakkumine"
>
  <div class="promotion-banner__glow" aria-hidden="true"></div>
  <div class="promotion-banner__pattern" aria-hidden="true">
    <svg viewBox="0 0 200 40" preserveAspectRatio="none" class="h-full w-full opacity-[0.07]">
      <path d="M0 20 Q50 0 100 20 T200 20 V40 H0 Z" fill="white" />
    </svg>
  </div>

  <div class="promotion-banner__inner max-w-7xl mx-auto">
    <div class="promotion-banner__copy">
      <div class="promotion-banner__badge">
        <svg class="promotion-banner__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linejoin="round"
          />
        </svg>
        <span class="promotion-banner__label" data-lang="promoTitle">Eripakkumine</span>
      </div>
      <p class="promotion-banner__headline" data-lang="promoText">
        Kõikidele teenustele <strong class="promotion-banner__highlight">−50%</strong> kuni kuu lõpuni!
      </p>
      <p class="promotion-banner__subline" data-lang="promoSubtext">
        Väljasõit 0 € Tallinnas • Kohale 30–60 minutiga
      </p>
    </div>

    <div class="promotion-banner__cta">
      <a
        href={`tel:${phoneLink}`}
        class="promotion-banner__call"
        data-lang="callNow"
        aria-label="Helista kohe"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          />
        </svg>
        <span>HELISTA</span>
      </a>
    </div>
  </div>
</div>

<style>
  .promotion-banner {
    --promo-navy: #0d517c;
    --promo-blue: #007eb8;
    --promo-accent: #7ec8e8;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: #fff;
    background: linear-gradient(105deg, var(--promo-navy) 0%, #0a6a9a 42%, var(--promo-blue) 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 4px 24px rgba(13, 81, 124, 0.22);
    transform-origin: top center;
    animation: promoEnter 0.52s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .promotion-banner--home {
    position: fixed;
    top: var(--header-height, 56px);
    left: 0;
    right: 0;
    z-index: 45;
  }

  .promotion-banner--inner {
    position: relative;
    z-index: 30;
  }

  .promotion-banner__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 120% at 0% 50%, rgba(126, 200, 232, 0.22), transparent 55%),
      radial-gradient(ellipse 60% 100% at 100% 0%, rgba(255, 255, 255, 0.08), transparent 50%);
    pointer-events: none;
  }

  .promotion-banner__glow::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 0%,
      rgba(255, 255, 255, 0.04) 42%,
      rgba(255, 255, 255, 0.1) 50%,
      rgba(255, 255, 255, 0.04) 58%,
      transparent 100%
    );
    background-size: 220% 100%;
    background-position: 200% 0;
    animation: promoShimmer 2.4s ease-out 0.55s 1 both;
    pointer-events: none;
  }

  .promotion-banner__pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .promotion-banner__inner {
    position: relative;
    z-index: 1;
    animation: promoContentEnter 0.48s cubic-bezier(0.22, 1, 0.36, 1) 0.12s both;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 0.75rem 1rem;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .promotion-banner__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
      padding: 0.875rem 1.5rem;
    }
  }

  .promotion-banner__copy {
    flex: 1;
    min-width: 0;
    text-align: center;
  }

  @media (min-width: 768px) {
    .promotion-banner__copy {
      text-align: left;
    }
  }

  .promotion-banner__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.25rem;
    padding: 0.125rem 0.5rem 0.125rem 0.375rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(4px);
  }

  .promotion-banner__icon {
    width: 0.875rem;
    height: 0.875rem;
    color: var(--promo-accent);
  }

  .promotion-banner__label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.92);
  }

  @media (min-width: 640px) {
    .promotion-banner__label {
      font-size: 0.75rem;
    }
  }

  .promotion-banner__headline {
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.98);
  }

  @media (min-width: 640px) {
    .promotion-banner__headline {
      font-size: 0.9375rem;
    }
  }

  @media (min-width: 1024px) {
    .promotion-banner__headline {
      font-size: 1.0625rem;
    }
  }

  :global(.promotion-banner__highlight) {
    font-weight: 800;
    color: #fff;
    background: linear-gradient(180deg, #fff 0%, #b8e4f7 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    padding: 0 0.1em;
  }

  .promotion-banner__subline {
    margin-top: 0.2rem;
    font-size: 0.6875rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.78);
    font-weight: 500;
  }

  @media (min-width: 640px) {
    .promotion-banner__subline {
      font-size: 0.75rem;
    }
  }

  .promotion-banner__cta {
    flex-shrink: 0;
    width: 100%;
  }

  @media (min-width: 768px) {
    .promotion-banner__cta {
      width: auto;
    }
  }

  .promotion-banner__call {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    min-height: 2.5rem;
    padding: 0.5rem 1.125rem;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--promo-navy);
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 0.5rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
    transition:
      background 0.2s ease,
      transform 0.15s ease,
      box-shadow 0.2s ease;
  }

  .promotion-banner__call:hover {
    background: #fff;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.16);
  }

  .promotion-banner__call:active {
    transform: scale(0.98);
  }

  @media (min-width: 768px) {
    .promotion-banner__call {
      width: auto;
      min-height: 2.75rem;
      padding: 0.625rem 1.375rem;
      font-size: 0.875rem;
    }
  }


  @keyframes promoEnter {
    from {
      opacity: 0;
      transform: translateY(-0.625rem) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes promoContentEnter {
    from {
      opacity: 0;
      transform: translateY(0.35rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes promoShimmer {
    from {
      background-position: 200% 0;
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    to {
      background-position: -120% 0;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .promotion-banner,
    .promotion-banner__inner,
    .promotion-banner__glow::after {
      animation: none !important;
    }

    .promotion-banner {
      opacity: 1;
      transform: none;
    }

    .promotion-banner__inner {
      opacity: 1;
      transform: none;
    }

    .promotion-banner__glow::after {
      opacity: 0;
      background-position: 200% 0;
    }
  }
</style>
