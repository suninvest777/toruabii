---
import type { ServiceIconId } from '../../data/home-services';

interface Props {
  id: ServiceIconId;
  class?: string;
}

const { id, class: className = 'service-card-icon-svg' } = Astro.props;

const gradId = `svc-grad-${id}`;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={gradId} x1="4" y1="4" x2="20" y2="20" gradientUnits="userSpaceOnUse">
      <stop stop-color="#007eb8" />
      <stop offset="1" stop-color="#0d517c" />
    </linearGradient>
  </defs>

  {
    id === 'emergency' && (
      <>
        <path
          d="M12 3v3M12 18v3M3 12h3M18 12h3"
          stroke={`url(#${gradId})`}
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <path
          d="M12 8v4l2.5 2.5"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <circle cx="12" cy="12" r="7.25" stroke={`url(#${gradId})`} stroke-width="1.75" />
        <path
          d="M9.5 6.5h5l-.8 2.2h-3.4L9.5 6.5z"
          fill={`url(#${gradId})`}
          fill-opacity="0.2"
          stroke={`url(#${gradId})`}
          stroke-width="1.25"
          stroke-linejoin="round"
        />
      </>
    )
  }

  {
    id === 'clog' && (
      <>
        <path
          d="M8 5h8v3a4 4 0 01-8 0V5z"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
          stroke-linejoin="round"
        />
        <path
          d="M12 12v2.5c0 1.5 1.2 2.5 2.5 2.5"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
          stroke-linecap="round"
        />
        <path
          d="M6 17c2 1.5 4 2 6 2s4-.5 6-2"
          stroke={`url(#${gradId})`}
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <circle cx="12" cy="16.5" r="1" fill={`url(#${gradId})`} />
      </>
    )
  }

  {
    id === 'camera' && (
      <>
        <rect
          x="3.5"
          y="7"
          width="13"
          height="10"
          rx="2"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
        />
        <path
          d="M16.5 9.5l4-2v9l-4-2"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
          stroke-linejoin="round"
        />
        <circle cx="10" cy="12" r="2.25" stroke={`url(#${gradId})`} stroke-width="1.5" />
        <path d="M7 7l2-2h6l2 2" stroke={`url(#${gradId})`} stroke-width="1.5" stroke-linejoin="round" />
      </>
    )
  }

  {
    id === 'pressure' && (
      <>
        <path
          d="M6 10c0-2.2 2.7-4 6-4s6 1.8 6 4-2.7 4-6 4"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
        />
        <path
          d="M8 14c1.2 2 2.8 3 4 3s2.8-1 4-3"
          stroke={`url(#${gradId})`}
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <path
          d="M12 6V4M10 20h4"
          stroke={`url(#${gradId})`}
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <path
          d="M5 18h14"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
          stroke-linecap="round"
        />
      </>
    )
  }

  {
    id === 'toilet' && (
      <>
        <path
          d="M9 4h6v3H9V4z"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
          stroke-linejoin="round"
        />
        <path
          d="M8 7h8a3 3 0 010 6H8a3 3 0 010-6z"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
        />
        <path
          d="M10 16h4v2H10v-2z"
          stroke={`url(#${gradId})`}
          stroke-width="1.5"
          stroke-linejoin="round"
        />
        <ellipse cx="12" cy="19" rx="5" ry="1.25" stroke={`url(#${gradId})`} stroke-width="1.25" />
      </>
    )
  }

  {
    id === 'pipes' && (
      <>
        <path
          d="M4 9h6v6H4V9z"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
          stroke-linejoin="round"
        />
        <path
          d="M14 9h6v6h-6V9z"
          stroke={`url(#${gradId})`}
          stroke-width="1.75"
          stroke-linejoin="round"
        />
        <path
          d="M10 12h4"
          stroke={`url(#${gradId})`}
          stroke-width="2"
          stroke-linecap="round"
        />
        <circle cx="12" cy="12" r="1.75" fill={`url(#${gradId})`} />
        <path
          d="M7 12H5M19 12h-2"
          stroke={`url(#${gradId})`}
          stroke-width="1.5"
          stroke-linecap="round"
        />
      </>
    )
  }
</svg>
