---
const partners = [
  { name: 'Tallinn', labelEt: 'Tallinn ja linnaosad', labelRu: 'Таллин и районы' },
  { name: 'Harjumaa', labelEt: 'Harjumaa vald', labelRu: 'Волость Харью' },
  { name: 'KÜ', labelEt: 'Korteriühistud', labelRu: 'КУ / ТСЖ' },
  { name: 'Ettevõtted', labelEt: 'Ärihooned', labelRu: 'Коммерческие объекты' },
  { name: 'Eramajad', labelEt: 'Erakliendid', labelRu: 'Частные клиенты' },
];
const trackItems = [...partners, ...partners];
---

<section class="py-14 px-4 home-surface-alt overflow-hidden font-body">
  <div class="max-w-7xl mx-auto">
    <h2 class="font-display text-2xl md:text-3xl font-bold home-text text-center mb-10">
      <span class="home-ssr-et">Meie kliendid ja koostööpartnerid</span>
      <span class="home-ssr-ru">Наши клиенты и партнёры</span>
    </h2>
    <div class="relative overflow-hidden mask-fade">
      <div class="partners-track">
        {trackItems.map((p) => (
          <div class="flex-shrink-0 w-48 md:w-56 h-24 rounded-xl home-card shadow-sm flex flex-col items-center justify-center px-4 text-center">
            <span class="font-display font-bold text-brand-blue text-lg">{p.name}</span>
            <span class="text-xs home-text-muted mt-1 home-ssr-et">{p.labelEt}</span>
            <span class="text-xs home-text-muted mt-1 home-ssr-ru">{p.labelRu}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .mask-fade {
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
</style>
