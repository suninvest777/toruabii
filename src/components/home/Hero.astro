---
import { SITE_IDENTITY } from '../../data/site-identity';
import { seoHomeH1 } from '../../data/seo-keywords';

const phoneLink = SITE_IDENTITY.phoneTel;
---

<section class="hero-section relative min-h-[min(85vh,720px)] flex items-center overflow-hidden font-body">
  <div class="absolute inset-0 z-0">
    <picture class="block w-full h-full">
      <source
        media="(max-width: 767px)"
        srcset="/photos/mobileversion-main.webp"
        type="image/webp"
      />
      <img
        src="/photos/maintoruabii.webp"
        alt="Toruabi ja avarii toruabi Tallinnas — meister tööl 24/7"
        class="w-full h-full object-cover"
        style="object-position: center 30%;"
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1080"
      />
    </picture>
    <div class="absolute inset-0 hero-overlay" aria-hidden="true"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 py-16 md:py-24 w-full">
    <div class="max-w-2xl text-white hero-copy">
      <h1 class="font-display text-[2.75rem] md:text-5xl lg:text-[3.75rem] lg:leading-[1.15] font-bold leading-[1.2] mb-6">
        <span class="home-ssr-et">{seoHomeH1('et')}</span>
        <span class="home-ssr-ru">{seoHomeH1('ru')}</span>
      </h1>
      <p class="font-sans text-lg font-normal text-white mb-8 leading-relaxed max-w-xl">
        <span class="home-ssr-et">
          Ehitame ja hooldame vee-, kanalisatsiooni-, kütte ning välistrasse Tallinnas ja Harjumaal.
        </span>
        <span class="home-ssr-ru">
          Строим и обслуживаем водопровод, канализацию, отопление и наружные сети в Таллинне и Харьюмаа.
        </span>
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#kontaktivorm" class="inline-flex items-center justify-center gap-2 bg-brand-blue hover:bg-brand-blue-dark text-white font-semibold px-8 py-4 rounded-xl transition-colors min-h-[52px] shadow-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
          <span class="home-ssr-et">Võta ühendust</span>
          <span class="home-ssr-ru">Связаться</span>
        </a>
        <a href="#teenused" class="inline-flex items-center justify-center gap-2 bg-white text-brand-blue border-2 border-brand-blue hover:bg-brand-blue-light font-semibold px-8 py-4 rounded-xl transition-colors min-h-[52px]">
          <span class="home-ssr-et">Vaata teenuseid</span>
          <span class="home-ssr-ru">Смотреть услуги</span>
        </a>
        <a
          href={`tel:${phoneLink}`}
          class="sm:hidden inline-flex items-center justify-center bg-white text-brand-blue font-bold px-8 py-4 rounded-lg min-h-[52px]"
        >
          {SITE_IDENTITY.phoneDisplay}
        </a>
      </div>
    </div>
  </div>
</section>
