---
// Callback Form — POST /api/callback → Telegram (source: toruabii.ee)
interface Props {
  variant?: 'default' | 'home';
}

const { variant = 'default' } = Astro.props;
const formAction = '/api/callback';

const wrapClass =
  variant === 'home'
    ? 'bg-surface-soft border border-brand-blue/20 rounded-xl p-6 mb-8 shadow-sm'
    : 'bg-caution-yellow/10 border-2 border-caution-yellow rounded-xl p-6 mb-8';

const submitClass =
  variant === 'home'
    ? 'w-full bg-brand-blue hover:bg-brand-blue-dark text-white font-bold py-4 px-6 rounded-xl transition-colors min-h-[48px] flex items-center justify-center'
    : 'w-full bg-emergency-red hover:bg-red-700 text-white font-bold py-4 px-6 rounded-xl transition-colors min-h-[48px] flex items-center justify-center';

const inputFocusClass =
  variant === 'home'
    ? 'focus:ring-2 focus:ring-brand-blue focus:border-transparent'
    : 'focus:ring-2 focus:ring-emergency-red focus:border-transparent';

const phoneLinkClass =
  variant === 'home' ? 'text-brand-blue font-bold hover:underline' : 'text-emergency-red font-bold';
---

<div class={wrapClass}>
  <h3 class="text-2xl font-bold text-trust-blue mb-4 font-display">
    {variant === 'home' ? (
      <>
        <span class="home-ssr-et">Tellida tagasiside</span>
        <span class="home-ssr-ru">Заказать обратный звонок</span>
      </>
    ) : (
      <span data-lang="callback">Tellida tagasiside</span>
    )}
  </h3>
  
  <form 
    action={formAction}
    method="POST"
    class="space-y-4"
    id="callback-form"
  >
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
        <span data-lang="name">Nimi</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class:list={['w-full px-4 py-2 border border-gray-300 rounded-xl', inputFocusClass]}
        data-lang="name"
        placeholder=""
      />
    </div>
    
    <div>
      <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
        <span data-lang="phoneLabel">Telefon</span>
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        required
        class:list={['w-full px-4 py-2 border border-gray-300 rounded-xl', inputFocusClass]}
        placeholder="+372 5181 112"
      />
    </div>
    
    <button type="submit" class={submitClass}>
      <span data-lang="send">Saada</span>
    </button>
  </form>
  
  <p class="text-sm text-gray-600 mt-4 text-center">
    <span data-lang="orCall">Või helista otse:</span> <a href="tel:+3725181112" class={phoneLinkClass}>+372 5181 112</a>
  </p>
</div>

<div id="form-message" class="hidden mt-4 p-4 rounded-xl text-center font-medium"></div>

<script>
  import { submitCallbackRequest } from '../scripts/callback-fetch';

  (function () {
    'use strict';

    const form = document.getElementById('callback-form');
    const messageDiv = document.getElementById('form-message');
    
    if (!form || !messageDiv) return;
    
    // Get translations
    const getTranslation = (key) => {
      const lang = localStorage.getItem('lang') || 'et';
      const translations = {
        et: {
          success: 'Aitäh! Võtame teiega ühendust varsti.',
          error: 'Viga saatmisel. Palun proovige uuesti või helistage otse.',
          sending: 'Saadetakse...'
        },
        ru: {
          success: 'Спасибо! Мы свяжемся с вами в ближайшее время.',
          error: 'Ошибка при отправке. Пожалуйста, попробуйте снова или позвоните напрямую.',
          sending: 'Отправляется...'
        }
      };
      return translations[lang]?.[key] || translations.et[key];
    };
    
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const submitButton = form.querySelector('button[type="submit"]');
      const originalButtonText = submitButton?.innerHTML;
      
      // Disable button and show loading state
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.innerHTML = `<span>${getTranslation('sending')}</span>`;
      }
      
      // Hide previous messages
      messageDiv.classList.add('hidden');
      messageDiv.classList.remove('bg-green-100', 'text-green-800', 'bg-red-100', 'text-red-800');
      
      try {
        const formData = new FormData(form);
        const name = (formData.get('name')?.toString() ?? '').trim();
        const phone = (formData.get('phone')?.toString() ?? '').trim();

        const result = await submitCallbackRequest({ name, phone });

        if (import.meta.env.DEV) {
          console.warn('[callback]', result.status, result.data, result.rawHint);
        }

        if (result.ok && result.data.success) {
          messageDiv.classList.remove('hidden');
          messageDiv.classList.add('bg-green-100', 'text-green-800');
          messageDiv.textContent = getTranslation('success');
          form.reset();
          setTimeout(() => {
            messageDiv.classList.add('hidden');
          }, 5000);
        } else {
          messageDiv.classList.remove('hidden');
          messageDiv.classList.add('bg-red-100', 'text-red-800');
          messageDiv.textContent =
            result.data.error?.trim() || getTranslation('error');
        }
      } catch (error) {
        console.error('Form submission error:', error);
        messageDiv.classList.remove('hidden');
        messageDiv.classList.add('bg-red-100', 'text-red-800');
        messageDiv.textContent = getTranslation('error');
      } finally {
        // Re-enable button
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.innerHTML = originalButtonText || '<span data-lang="send">Saada</span>';
        }
      }
    });
  })();
</script>
