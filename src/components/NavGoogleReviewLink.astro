---
interface Props {
  variant: 'desktop' | 'mobile';
  /** Avaleht: keelepaarid ilma JS (html lang + CSS). */
  homeSsr?: boolean;
  /** Avalehe horisontaalmenüü: `<a>` ilma `<li>`, kompaktne sinine nupp. */
  homeNavInline?: boolean;
}

const { variant, homeSsr, homeNavInline } = Astro.props;

const blueDesktopClass =
  'inline-flex items-center justify-center rounded-lg bg-brand-blue px-3 py-2 text-sm font-semibold text-white shadow hover:bg-brand-blue-dark focus-visible:outline focus-visible:ring-2 focus-visible:ring-brand-blue focus-visible:ring-offset-2 whitespace-nowrap min-h-[44px] lg:px-4 lg:text-base';

const blueMobileClass =
  'block rounded-lg bg-brand-blue py-3 px-4 text-center text-white font-semibold shadow hover:bg-brand-blue-dark';

const yellowDesktopClass =
  'inline-flex items-center justify-center rounded-lg bg-caution-yellow px-3 py-2 text-sm font-bold text-trust-blue shadow hover:brightness-95 focus-visible:outline focus-visible:ring-2 focus-visible:ring-caution-yellow focus-visible:ring-offset-2 focus-visible:ring-offset-trust-blue whitespace-nowrap min-h-[44px] lg:px-4 lg:text-base';

const yellowMobileClass =
  'block rounded-lg bg-caution-yellow py-3 px-4 text-center text-trust-blue font-bold shadow hover:brightness-95';

const homeNavInlineClass =
  'inline-flex items-center justify-center rounded-md bg-brand-blue px-2.5 py-1.5 text-xs font-semibold text-white shadow-sm hover:bg-brand-blue-dark focus-visible:outline focus-visible:ring-2 focus-visible:ring-brand-blue focus-visible:ring-offset-2 whitespace-nowrap shrink-0 min-h-0';

const desktopClass = homeNavInline
  ? homeNavInlineClass
  : homeSsr
    ? blueDesktopClass
    : yellowDesktopClass;
const mobileClass = homeSsr ? blueMobileClass : yellowMobileClass;
---

{
  variant === 'desktop' && homeNavInline ? (
    <a
      href="/tagasiside-soodus"
      class={desktopClass}
      {...(homeSsr ? {} : { 'data-lang': 'navGoogleReview' })}
    >
      {homeSsr ? (
        <>
          <span class="home-ssr-et">Google'i tagasiside</span>
          <span class="home-ssr-ru">Отзыв в Google</span>
        </>
      ) : (
        <>Google'i tagasiside</>
      )}
    </a>
  ) : variant === 'desktop' ? (
    <li>
      <a
        href="/tagasiside-soodus"
        class={desktopClass}
        {...(homeSsr ? {} : { 'data-lang': 'navGoogleReview' })}
      >
        {homeSsr ? (
          <>
            <span class="home-ssr-et">Google'i tagasiside</span>
            <span class="home-ssr-ru">Отзыв в Google</span>
          </>
        ) : (
          <>Google'i tagasiside</>
        )}
      </a>
    </li>
  ) : (
    <li>
      <a
        href="/tagasiside-soodus"
        class={mobileClass}
        {...(homeSsr ? {} : { 'data-lang': 'navGoogleReview' })}
      >
        {homeSsr ? (
          <>
            <span class="home-ssr-et">Google'i tagasiside</span>
            <span class="home-ssr-ru">Отзыв в Google</span>
          </>
        ) : (
          <>Google'i tagasiside</>
        )}
      </a>
    </li>
  )
}
