---

import BaseLayout from '../layouts/BaseLayout.astro';
import HomePageIndex from '../components/home/HomePageIndex.astro';
import {
  seoHomeDescription,
  seoHomeOgDescription,
  seoHomeTitle,
} from '../data/seo-keywords';

const homeTitle = seoHomeTitle('et');
const homeDescription = seoHomeDescription('et');
const homeOgDescription = seoHomeOgDescription('et');
---

<BaseLayout
  title={homeTitle}
  description={homeDescription}
  ogDescription={homeOgDescription}
  lang="et"
  canonical="https://toruabii.ee/"
  ogImage="https://toruabii.ee/photos/maintoruabii.webp"
  homeTheme
>
  <HomePageIndex lang="et" />
</BaseLayout>
