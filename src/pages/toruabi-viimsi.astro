---
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import DistrictCrossLinks from '../components/DistrictCrossLinks.astro';
import FooterLegal from '../components/FooterLegal.astro';
import CallStripCta from '../components/CallStripCta.astro';
import DistrictTallinnJsonLd from '../components/seo/DistrictTallinnJsonLd.astro';
import { tallinnDistrictBreadcrumbJsonLd, tallinnDistrictPageUrl } from '../utils/district-tallinn-jsonld';
import { pageLang } from '../utils/page-lang';
import {
  getTallinnDistrict,
  tallinnDistrictDescription,
  tallinnDistrictH1,
  tallinnDistrictIntro,
  tallinnDistrictTitle,
} from '../data/seo-keywords';

const siteUrl = 'https://toruabii.ee';
const districtSeo = getTallinnDistrict('viimsi');

const phoneNumber = '+372 5181 112';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = pageLang(Astro.url);

const titleEt = tallinnDistrictTitle('viimsi', 'et');
const descEt = tallinnDistrictDescription('viimsi', 'et');
const titleRu = tallinnDistrictTitle('viimsi', 'ru');
const descRu = tallinnDistrictDescription('viimsi', 'ru');

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const districtPath = '/toruabi-viimsi';
const pageCanonicalUrl = tallinnDistrictPageUrl(districtPath, currentLang);
const breadcrumbJsonLdOverride = tallinnDistrictBreadcrumbJsonLd(districtPath, currentLang, titleEt, titleRu);

const viimsiFaqEt = [
  {
    q: 'Kui kiiresti saab toruabi Viimsisse?',
    a: 'Viimsi piirkonnas jõuame tavaliselt 30-50 minutiga kohale. Avariikõnedele reageerime kohe. Toruabi Viimsis 24/7!',
  },
  {
    q: 'Millised on toruabi hinnad Viimsis?',
    a: 'Toruabi hinnad Viimsis on samad, mis kogu Tallinnas. Väljasõit on 0€. Vaata täielikku hinnakirja meie veebilehelt.',
  },
  {
    q: 'Kas toruabi töötab Viimsis ööpäevaringselt?',
    a: 'Jah, oleme kättesaadavad 24/7 avariikõnedele Viimsis. Planeeritud tööde jaoks töötame tavapäraselt kella 8-20 vahel.',
  },
  {
    q: 'Kas teil on kogemus Viimsi eramute ja villadega?',
    a: 'Jah, meil on pikk kogemus töötamisega Viimsi eramutes ja villades. Tunneme nende hoonete spetsiifikaid (mereline kliima, korrosiooniprobleemid) ja teame, kuidas kiiresti lahendada probleeme. Toruabi Viimsis 24/7!',
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={pageCanonicalUrl}
  ogImage="https://toruabii.ee/photos/maintoruabii.webp"
  suppressPlumbingJsonLd
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <DistrictTallinnJsonLd
    slot="head"
    districtPath={districtPath}
    currentLang={currentLang}
    pageDescription={pageDescription}
    addressLocality="Viimsi"
    areaServedName="Viimsi"
    plumbingDisplayNameEt="toruabii.ee - Toruabi Viimsis"
    plumbingDisplayNameRu="toruabii.ee — торуаби во Виймси"
    offerCatalogNameEt="Toruabi teenused Viimsis"
    offers={[
      {
        nameEt: 'Toruabi Viimsis',
        descEt: 'Avarii toruabi ja kanalisatsiooni toruabi Viimsi piirkonnas 24/7',
      },
      {
        nameEt: 'Kanalisatsiooni toruabi Viimsis',
        descEt: 'Kanalisatsiooni ummistuste likvideerimine ja hooldus Viimsi piirkonnas',
      },
      {
        nameEt: 'Boileri toruabi Viimsis',
        descEt: 'Boileri hooldus, läbipesu ja remont Viimsi piirkonnas',
      },
    ]}
    faqEt={viimsiFaqEt}
  />
  <!-- Desktop Navigation -->
  
  <!-- Hero Section -->
  <header class="bg-trust-blue text-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <Breadcrumb
        items={[
          { name: currentLang === 'ru' ? 'Главная' : 'Avaleht', url: currentLang === 'ru' ? siteUrl + '/ru' : siteUrl + '/' },
          { name: currentLang === 'ru' ? 'Торуаби по районам' : 'Toruabi piirkondades', url: siteUrl + '/#piirkonnad' },
          { name: currentLang === 'ru' ? 'Торуаби в Виймси' : 'Toruabi Viimsis', url: siteUrl + '/toruabi-viimsi' }
        ]}
        class="text-gray-300 mb-3"
      />
      {currentLang === 'ru' ? (
        <a href="/ru" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">← На главную</a>
      ) : (
        <a href="/" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">← Tagasi avalehele</a>
      )}
      <h1 class="text-4xl md:text-5xl font-bold mb-3">{currentLang === 'ru' ? tallinnDistrictH1('viimsi', 'ru') : tallinnDistrictH1('viimsi', 'et')}</h1>
      <p class="text-xl text-gray-200 mb-6">{currentLang === 'ru' ? tallinnDistrictIntro('viimsi', 'ru') : tallinnDistrictIntro('viimsi', 'et')}</p>
      <a href={`tel:${phoneLink}`} class="inline-block bg-emergency-red hover:bg-red-700 text-white font-bold py-4 px-8 rounded-lg text-xl">
        <span data-lang="callNowFull">HELISTA KOHE</span>: {phoneNumber}
      </a>
    </div>
  </header>

  <main class="py-12 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto space-y-12">

      <CallStripCta variant="page" />
      
      <!-- Why Choose Toruabi Viimsis -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Miks valida toruabi Viimsis?</h2>
        <h3 class="text-lg font-semibold text-trust-blue mb-3">Peamised põhjused</h3>
        <p class="text-gray-700 mb-4">Viimsi vald ühendab Tallinna piiriga korterid ja eraldiseisvad villad, kus boiler ja kanalisatsioon vajavad sageli hooajalist kontrolli. Teenindame Haabneeme, Randvere ja Tammneeme kandi objekte, arvestades rannikuteede ja eramu sügavamate trassidega.</p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Kohalik ekspert:</strong> Meie meistrid töötavad Viimsis regulaarselt ja tunnevad piirkonna spetsiifikaid (uued eramud, kaasaegsed süsteemid)</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Kiire reageerimine:</strong> Viimsi piirkonnas jõuame kohale tavaliselt 30-50 minutiga</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Uusarenduste kogemus:</strong> Meil on pikk kogemus töötamisega Viimsi uusarendustes, eramutes ja villades</li>
        </ul>
        
        <div class="bg-trust-blue text-white rounded-lg p-6 mt-6">
          <h3 class="text-2xl font-bold mb-4">Toruabi Viimsis – meie statistikat</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-bold mb-2">287+</div>
              <p class="text-gray-200">Rahulolu klienti Viimsis</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">38 min</div>
              <p class="text-gray-200">Keskmine reageerimisaeg</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">7+</div>
              <p class="text-gray-200">Aastat kogemust Viimsis</p>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Почему выбирают торуаби в Виймси?</h2>
        <h3 class="text-lg font-semibold text-trust-blue mb-3">Основные причины</h3>
        <p class="text-gray-700 mb-4">Виймси – элитный район Таллина, где много новых частных домов, вилл и новостроек. Наша команда хорошо знает район и быстро реагирует на аварийные вызовы.</p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Местный эксперт:</strong> Наши мастера регулярно работают в Виймси и знают специфику района (новые дома, современные системы)</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Быстрое реагирование:</strong> В районе Виймси мы обычно приезжаем за 30-50 минут</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Опыт работы в новостройках:</strong> У нас большой опыт работы в новостройках, частных домах и виллах Виймси</li>
        </ul>
        
        <div class="bg-trust-blue text-white rounded-lg p-6 mt-6">
          <h3 class="text-2xl font-bold mb-4">Торуаби в Виймси – наша статистика</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-bold mb-2">287+</div>
              <p class="text-gray-200">Довольных клиентов в Виймси</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">38 мин</div>
              <p class="text-gray-200">Среднее время реагирования</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">7+</div>
              <p class="text-gray-200">Лет опыта в Виймси</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Services in Viimsi -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi teenused Viimsis</h2>
        <p class="text-gray-700 mb-6">Viimsi piirkonnas pakume kõiki toruabi teenuseid 24/7, sealhulgas:</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Toruabi Viimsi uusarendustes ja eramutes</h3>
            <p class="text-gray-700 mb-3">Haabneeme ja Pringi uued eramud kasutavad sageli soojuspumpasid ja eraldi kanalisatsioonikaevu — hooldame filtreid, lekkeid ja kaasaegseid plasttrasse ilma fassaadi lõhkumata.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Kanalisatsiooni toruabi ja ummistuste likvideerimine</li>
              <li>Kaasaegsete küttesüsteemide toruabi ja hooldus</li>
              <li>Boileri toruabi ja läbipesu</li>
              <li>Torustike remont ja renoveerimine</li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Kanalisatsiooni toruabi Viimsi villades</h3>
            <p class="text-gray-700 mb-3">Randvere ja Tammneeme villades on pikemad sõiduteed ja sügavamad trassid — videouuring ja survepesu aitavad leida ummistuse ilma suurema kaevamiseta.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Survepesu kanalisatsioonisüsteemidest</li>
              <li>Videouuring torustiku seisukorra kontrollimiseks</li>
              <li>Rasvapüüduri puhastamine</li>
              <li>Kanalisatsioonitrasside renoveerimine</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Услуги торуаби в Виймси</h2>
        <p class="text-gray-700 mb-6">В районе Виймси мы предлагаем все услуги торуаби 24/7, включая:</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Торуаби в новостройках и частных домах Виймси</h3>
            <p class="text-gray-700 mb-3">В Хаабнеэме и Принги — тепловые насосы и отдельные колодцы: обслуживаем фильтры, протечки и пластиковые трассы без повреждения фасада.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Прочистка канализации и устранение засоров</li>
              <li>Обслуживание современных систем отопления</li>
              <li>Обслуживание и промывка бойлеров</li>
              <li>Ремонт и реконструкция трубопроводов</li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Прочистка канализации в виллах Виймси</h3>
            <p class="text-gray-700 mb-3">В Рандвере и Таммнеэме — длинные подъезды и глубокие линии; видеодиагностика и промывка без крупной раскопки.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Гидродинамическая промывка канализационных систем</li>
              <li>Видеообследование для проверки состояния трубопроводов</li>
              <li>Очистка жироуловителей</li>
              <li>Реконструкция канализационных трасс</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Reviews -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi Viimsis – kliendiarvustused</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Helle V.</span>
            </div>
            <p class="text-gray-700 mb-2">"Haabneeme eramus kontrolliti soojuspumba leke ja torustik — töö tehti ühe visiidiga, selge arve ja garantii."</p>
            <p class="text-sm text-gray-500">8. jaanuar 2026</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Kadri M.</span>
            </div>
            <p class="text-gray-700 mb-2">"Pringi villas tehti kanalisatsiooni videouuring ja survepesu — ummistus kadus ilma aeda kaevamata."</p>
            <p class="text-sm text-gray-500">28. november 2025</p>
          </div>
        </div>
        <p class="text-center mt-6 text-gray-600">Keskmine hinnang: <span class="font-bold text-trust-blue">4.9/5</span> (287 arvustust)</p>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Торуаби в Виймси – отзывы клиентов</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Хелле В.</span>
            </div>
            <p class="text-gray-700 mb-2">"В Хаабнеэме устранили течь теплового насоса и проверили трубы за один визит — понятный счёт и гарантия."</p>
            <p class="text-sm text-gray-500">8 января 2026</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Кадри М.</span>
            </div>
            <p class="text-gray-700 mb-2">"В Принги сделали видеообследование и промывку канализации — засор ушёл без копания газона."</p>
            <p class="text-sm text-gray-500">28 ноября 2025</p>
          </div>
        </div>
        <p class="text-center mt-6 text-gray-600">Средняя оценка: <span class="font-bold text-trust-blue">4.9/5</span> (287 отзывов)</p>
      </section>

      <!-- Areas in Viimsi -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi Viimsi piirkonnad</h2>
        <p class="text-gray-700 mb-4">Teenindame kõiki Viimsi piirkondi, sealhulgas:</p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Viimsi</h3>
            <p class="text-sm text-gray-600">Toruabi Viimsi piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Haabneeme</h3>
            <p class="text-sm text-gray-600">Toruabi Haabneemes</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Pringi</h3>
            <p class="text-sm text-gray-600">Toruabi Pringi piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Randvere</h3>
            <p class="text-sm text-gray-600">Toruabi Randveres</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Tammneeme</h3>
            <p class="text-sm text-gray-600">Toruabi Tammneemes</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Lubja</h3>
            <p class="text-sm text-gray-600">Toruabi Lubja piirkonnas</p>
          </div>
        </div>
        <div class="bg-trust-blue text-white rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Toruabi ka teistes Tallinna piirkondades</h3>
          <p class="text-gray-200 mb-3">Teenindame ka teisi Tallinna piirkondi:</p>
          <ul class="space-y-2">
            <li><a href="/toruabi-lasnamae" class="text-emergency-red hover:underline font-semibold">Toruabi Lasnamäes</a> – kiire avarii toruabi ja kanalisatsiooni toruabi Lasnamäe piirkonnas</li>
            <li><a href="/toruabi-mustamae" class="text-emergency-red hover:underline font-semibold">Toruabi Mustamäel</a> – professionaalne avarii toruabi Mustamäe piirkonnas</li>
            <li><a href="/toruabi-kesklinn" class="text-emergency-red hover:underline font-semibold">Toruabi Kesklinnas</a> – kiire avarii toruabi Tallinna kesklinna piirkonnas</li>
            <li><a href="/toruabi-pirita" class="text-emergency-red hover:underline font-semibold">Toruabi Piritas</a> – toruabi Pirita ja Merivälja piirkonnas</li>
          </ul>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Районы обслуживания торуаби в Виймси</h2>
        <p class="text-gray-700 mb-4">Мы обслуживаем все районы Виймси, включая:</p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Виймси</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Виймси</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Хаабнеэме</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Хаабнеэме</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Принги</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Принги</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Лубья</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Лубья</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Рохунээме</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Рохунээме</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Строоми</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Строоми</p>
          </div>
        </div>
        <div class="bg-trust-blue text-white rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Торуаби также в других районах Таллина</h3>
          <p class="text-gray-200 mb-3">Мы также обслуживаем другие районы Таллина:</p>
          <ul class="space-y-2">
            <li><a href="/toruabi-lasnamae" class="text-emergency-red hover:underline font-semibold">Торуаби в Ласнамяэ</a> – быстрая аварийная сантехника и прочистка канализации в районе Ласнамяэ</li>
            <li><a href="/toruabi-mustamae" class="text-emergency-red hover:underline font-semibold">Торуаби в Мустамяэ</a> – профессиональная аварийная сантехника в районе Мустамяэ</li>
            <li><a href="/toruabi-kesklinn" class="text-emergency-red hover:underline font-semibold">Торуаби в Кесклинне</a> – быстрая аварийная сантехника в центре Таллина</li>
            <li><a href="/toruabi-pirita" class="text-emergency-red hover:underline font-semibold">Торуаби в Пирита</a> – сантехника в Пирита и Меривялья</li>
          </ul>
        </div>
