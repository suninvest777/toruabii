---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePageIndex from '../../components/home/HomePageIndex.astro';
import {
  seoHomeDescription,
  seoHomeOgDescription,
  seoHomeTitle,
} from '../../data/seo-keywords';

const siteUrl = 'https://toruabii.ee';
const title = seoHomeTitle('ru');
const description = seoHomeDescription('ru');
const ogDescription = seoHomeOgDescription('ru');
---

<BaseLayout
  title={title}
  description={description}
  ogDescription={ogDescription}
  lang="ru"
  canonical={`${siteUrl}/ru`}
  ogImage={`${siteUrl}/photos/maintoruabii.webp`}
  homeTheme
>
  <HomePageIndex lang="ru" />
</BaseLayout>
