---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import DistrictCrossLinks from '../components/DistrictCrossLinks.astro';
import FooterLegal from '../components/FooterLegal.astro';
import NavGoogleReviewLink from '../components/NavGoogleReviewLink.astro';
import CallStripCta from '../components/CallStripCta.astro';
import DistrictTallinnJsonLd from '../components/seo/DistrictTallinnJsonLd.astro';
import { tallinnDistrictBreadcrumbJsonLd } from '../utils/district-tallinn-jsonld';
import {
  getTallinnDistrict,
  tallinnDistrictDescription,
  tallinnDistrictH1,
  tallinnDistrictIntro,
  tallinnDistrictTitle,
} from '../data/seo-keywords';

const siteUrl = 'https://toruabii.ee';
const districtSeo = getTallinnDistrict('pirita');

const phoneNumber = '+372 5181 112';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = Astro.url.searchParams.get('lang') === 'ru' ? 'ru' : 'et';

const titleEt = tallinnDistrictTitle('pirita', 'et');
const descEt = tallinnDistrictDescription('pirita', 'et');
const titleRu = tallinnDistrictTitle('pirita', 'ru');
const descRu = tallinnDistrictDescription('pirita', 'ru');

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const districtPath = '/toruabi-pirita';
const breadcrumbJsonLdOverride = tallinnDistrictBreadcrumbJsonLd(districtPath, currentLang, titleEt, titleRu);

const piritaFaqEt = [
  {
    q: 'Kui kiiresti saab toruabi Piritasse?',
    a: 'Pirita piirkonnas jõuame tavaliselt 30-50 minutiga kohale. Avariikõnedele reageerime kohe. Toruabi Piritas 24/7!',
  },
  {
    q: 'Millised on toruabi hinnad Piritas?',
    a: 'Toruabi hinnad Piritas on samad, mis kogu Tallinnas. Väljasõit on 0€. Vaata täielikku hinnakirja meie veebilehelt.',
  },
  {
    q: 'Kas toruabi töötab Piritas ööpäevaringselt?',
    a: 'Jah, oleme kättesaadavad 24/7 avariikõnedele Piritas. Planeeritud tööde jaoks töötame tavapäraselt kella 8-20 vahel.',
  },
  {
    q: 'Kas teil on kogemus Pirita eramute ja villadega?',
    a: 'Jah, meil on pikk kogemus töötamisega Pirita eramutes ja villades. Tunneme nende hoonete spetsiifikaid (mereline kliima, korrosiooniprobleemid) ja teame, kuidas kiiresti lahendada probleeme. Toruabi Piritas 24/7!',
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical="https://toruabii.ee/toruabi-pirita"
  ogImage="https://toruabii.ee/photos/maintoruabii.webp"
  keywords={currentLang === 'ru' ? districtSeo.keywordsRu : districtSeo.keywordsEt}
  suppressPlumbingJsonLd
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <DistrictTallinnJsonLd
    slot="head"
    districtPath={districtPath}
    currentLang={currentLang}
    pageDescription={pageDescription}
    addressLocality="Pirita"
    areaServedName="Pirita"
    plumbingDisplayNameEt="toruabii.ee - Toruabi Piritas"
    plumbingDisplayNameRu="toruabii.ee — торуаби в Пирита"
    offerCatalogNameEt="Toruabi teenused Piritas"
    offers={[
      {
        nameEt: 'Toruabi Piritas',
        descEt: 'Avarii toruabi ja kanalisatsiooni toruabi Pirita piirkonnas 24/7',
      },
      {
        nameEt: 'Kanalisatsiooni toruabi Piritas',
        descEt: 'Kanalisatsiooni ummistuste likvideerimine ja hooldus Pirita piirkonnas',
      },
      {
        nameEt: 'Boileri toruabi Piritas',
        descEt: 'Boileri hooldus, läbipesu ja remont Pirita piirkonnas',
      },
    ]}
    faqEt={piritaFaqEt}
  />
  <!-- Desktop Navigation -->
  
  <!-- Hero Section -->
  <header class="bg-trust-blue text-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <Breadcrumb
        items={[
          { name: currentLang === 'ru' ? 'Главная' : 'Avaleht', url: currentLang === 'ru' ? siteUrl + '/ru' : siteUrl + '/' },
          { name: currentLang === 'ru' ? 'Торуаби по районам' : 'Toruabi piirkondades', url: siteUrl + '/#piirkonnad' },
          { name: currentLang === 'ru' ? 'Торуаби в Пирита' : 'Toruabi Piritas', url: siteUrl + '/toruabi-pirita' }
        ]}
        class="text-gray-300 mb-3"
      />
      <a href="/" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold blog-et">← Tagasi avalehele</a>
      <a href="/ru" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold blog-ru">← На главную</a>
      <h1 class="text-4xl md:text-5xl font-bold mb-3 blog-et">{tallinnDistrictH1('pirita', 'et')}</h1>
      <h1 class="text-4xl md:text-5xl font-bold mb-3 blog-ru">{tallinnDistrictH1('pirita', 'ru')}</h1>
      <p class="text-xl text-gray-200 mb-6 blog-et">{tallinnDistrictIntro('pirita', 'et')}</p>
      <p class="text-xl text-gray-200 mb-6 blog-ru">{tallinnDistrictIntro('pirita', 'ru')}</p>
      <a href={`tel:${phoneLink}`} class="inline-block bg-emergency-red hover:bg-red-700 text-white font-bold py-4 px-8 rounded-lg text-xl">
        <span data-lang="callNowFull">HELISTA KOHE</span>: {phoneNumber}
      </a>
    </div>
  </header>

  <main class="py-12 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto space-y-12">

      <CallStripCta variant="page" />
      
      <!-- Why Choose Toruabi Piritas -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Miks valida toruabi Piritas?</h2>
        <h3 class="text-lg font-semibold text-trust-blue mb-3">Peamised põhjused</h3>
        <p class="text-gray-700 mb-4">Piritas kohtuvad mereäärsed eramud, vana kivimaja fond ja uued elamukvartalid — iga objekti toruprobleem on teistsugune. Pirita toruabi tähendab meie jaoks niiskuskahjustuste ennetamist, suvila hooajalist hooldust ja kiiret ligipääsu Pirita tee ning Merivälja kandis.</p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Kohalik ekspert:</strong> Meie meistrid töötavad Piritas regulaarselt ja tunnevad piirkonna spetsiifikaid (mereline kliima, eramud, villad)</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Kiire reageerimine:</strong> Pirita piirkonnas jõuame kohale tavaliselt 30-50 minutiga</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Eramute kogemus:</strong> Meil on pikk kogemus töötamisega Pirita eramutes, villades ja korterites</li>
        </ul>
        
        <div class="bg-trust-blue text-white rounded-lg p-6 mt-6">
          <h3 class="text-2xl font-bold mb-4">Toruabi Piritas – meie statistikat</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-bold mb-2">312+</div>
              <p class="text-gray-200">Rahulolu klienti Piritas</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">40 min</div>
              <p class="text-gray-200">Keskmine reageerimisaeg</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">8+</div>
              <p class="text-gray-200">Aastat kogemust Piritas</p>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Почему выбирают торуаби в Пирита?</h2>
        <h3 class="text-lg font-semibold text-trust-blue mb-3">Основные причины</h3>
        <p class="text-gray-700 mb-4">Пирита – элитный район Таллина у моря, где много частных домов, вилл и квартир. Наша команда хорошо знает район и быстро реагирует на аварийные вызовы.</p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Местный эксперт:</strong> Наши мастера регулярно работают в Пирита и знают специфику района (морской климат, частные дома, виллы)</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Быстрое реагирование:</strong> В районе Пирита мы обычно приезжаем за 30-50 минут</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Опыт работы в частных домах:</strong> У нас большой опыт работы в частных домах, виллах и квартирах Пирита</li>
        </ul>
        
        <div class="bg-trust-blue text-white rounded-lg p-6 mt-6">
          <h3 class="text-2xl font-bold mb-4">Торуаби в Пирита – наша статистика</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-bold mb-2">312+</div>
              <p class="text-gray-200">Довольных клиентов в Пирита</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">40 мин</div>
              <p class="text-gray-200">Среднее время реагирования</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">8+</div>
              <p class="text-gray-200">Лет опыта в Пирита</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Services in Pirita -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi teenused Piritas</h2>
        <p class="text-gray-700 mb-6">Pirita piirkonnas pakume kõiki toruabi teenuseid 24/7, sealhulgas:</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Toruabi Pirita eramutes ja villades</h3>
            <p class="text-gray-700 mb-3">Pirita on tuntud oma eliitsete eramute ja villade poolest mere ääres. Meie toruabi meeskond ja kogenud torumees tunnevad nende hoonete spetsiifikaid ja teavad, kuidas töötada merelise kliimaga seotud probleemidega (korrosioon, niiskus). Pakume professionaalset kanalisatsiooni toruabi ja avarii toruabi teenuseid Pirita eramutes ja villades 24/7. Meie professionaalne santehnik ja avarii santehnik on spetsialiseerunud töötamisele Pirita eramutes.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Kanalisatsiooni toruabi ja ummistuste likvideerimine</li>
              <li>Küttesüsteemi toruabi ja hooldus</li>
              <li>Boileri toruabi ja läbipesu</li>
              <li>Torustike remont ja renoveerimine</li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Kanalisatsiooni toruabi Pirita korterites</h3>
            <p class="text-gray-700 mb-3">Pirita piirkonnas on ka palju kortereid, mis vajavad regulaarset toruabi hooldust. Meie toruabi meeskond ja kogenud avarii santehnik kasutavad professionaalseid seadmeid ummistuste eemaldamiseks. Meie torumees ja professionaalne santehnik tegelevad kanalisatsiooni toruabi ja sanitaartehniliste töödega Pirita korterites. Pakume toruabi teenuseid Piritas 24/7.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Survepesu kanalisatsioonisüsteemidest</li>
              <li>Videouuring torustiku seisukorra kontrollimiseks</li>
              <li>Rasvapüüduri puhastamine</li>
              <li>Kanalisatsioonitrasside renoveerimine</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Услуги торуаби в Пирита</h2>
        <p class="text-gray-700 mb-6">В районе Пирита мы предлагаем все услуги торуаби 24/7, включая:</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Торуаби в частных домах и виллах Пирита</h3>
            <p class="text-gray-700 mb-3">Пирита известен своими элитными частными домами и виллами у моря. Наша команда знает специфику этих зданий и умеет работать с проблемами, связанными с морским климатом (коррозия, влажность). Мы предоставляем профессиональные услуги по прочистке канализации и аварийной сантехнике в частных домах и виллах Пирита 24/7.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Прочистка канализации и устранение засоров</li>
              <li>Обслуживание систем отопления</li>
              <li>Обслуживание и промывка бойлеров</li>
              <li>Ремонт и реконструкция трубопроводов</li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Прочистка канализации в квартирах Пирита</h3>
            <p class="text-gray-700 mb-3">В районе Пирита также много квартир, которые требуют регулярного обслуживания сантехники. Наша команда использует профессиональное оборудование для устранения засоров. Мы предоставляем услуги по прочистке канализации и сантехническим работам в квартирах Пирита 24/7.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Гидродинамическая промывка канализационных систем</li>
              <li>Видеообследование для проверки состояния трубопроводов</li>
              <li>Очистка жироуловителей</li>
              <li>Реконструкция канализационных трасс</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Reviews -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi Piritas – kliendiarvustused</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Andres K.</span>
            </div>
            <p class="text-gray-700 mb-2">"Väga kiire ja professionaalne toruabi Piritas! Kanalisatsiooni ummistus eramajas lahendati kiiresti ja kvaliteetselt. Meister jõudis kohale 40 minutiga. Soovitan!"</p>
            <p class="text-sm text-gray-500">18. detsember 2025</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Kadri M.</span>
            </div>
            <p class="text-gray-700 mb-2">"Boileri hooldus Pirita villas tehti väga hästi. Meister oli professionaalne ja selgitas kõik selgelt. Garantii 2 aastat annab rahu. Toruabi Piritas 24/7 on suurepärane!"</p>
            <p class="text-sm text-gray-500">22. november 2025</p>
          </div>
        </div>
        <p class="text-center mt-6 text-gray-600">Keskmine hinnang: <span class="font-bold text-trust-blue">4.9/5</span> (312 arvustust)</p>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Торуаби в Пирита – отзывы клиентов</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Андрес К.</span>
            </div>
            <p class="text-gray-700 mb-2">"Очень быстрая и профессиональная торуаби в Пирита! Засор канализации в частном доме решили быстро и качественно. Мастер приехал за 40 минут. Рекомендую!"</p>
            <p class="text-sm text-gray-500">18 декабря 2025</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Кадри М.</span>
            </div>
            <p class="text-gray-700 mb-2">"Обслуживание бойлера в вилле Пирита сделали очень хорошо. Мастер был профессионален и всё объяснил. Гарантия 2 года даёт спокойствие. Торуаби в Пирита 24/7 отлично!"</p>
            <p class="text-sm text-gray-500">22 ноября 2025</p>
          </div>
        </div>
        <p class="text-center mt-6 text-gray-600">Средняя оценка: <span class="font-bold text-trust-blue">4.9/5</span> (312 отзывов)</p>
      </section>

      <!-- Areas in Pirita -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi Pirita piirkonnad</h2>
        <p class="text-gray-700 mb-4">Teenindame kõiki Pirita piirkondi, sealhulgas:</p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Pirita</h3>
            <p class="text-sm text-gray-600">Toruabi Pirita piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Merivälja</h3>
            <p class="text-sm text-gray-600">Toruabi Merivälja piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Kloostrimetsa</h3>
            <p class="text-sm text-gray-600">Toruabi Kloostrimetsa piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Iru</h3>
            <p class="text-sm text-gray-600">Toruabi Iru piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Mähe</h3>
            <p class="text-sm text-gray-600">Toruabi Mähe piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Lepiku</h3>
            <p class="text-sm text-gray-600">Toruabi Lepiku piirkonnas</p>
          </div>
        </div>
        <div class="bg-trust-blue text-white rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Toruabi ka teistes Tallinna piirkondades</h3>
          <p class="text-gray-200 mb-3">Teenindame ka teisi Tallinna piirkondi:</p>
          <ul class="space-y-2">
            <li><a href="/toruabi-lasnamae" class="text-emergency-red hover:underline font-semibold">Toruabi Lasnamäes</a> – kiire avarii toruabi ja kanalisatsiooni toruabi Lasnamäe piirkonnas</li>
            <li><a href="/toruabi-mustamae" class="text-emergency-red hover:underline font-semibold">Toruabi Mustamäel</a> – professionaalne avarii toruabi Mustamäe piirkonnas</li>
            <li><a href="/toruabi-kesklinn" class="text-emergency-red hover:underline font-semibold">Toruabi Kesklinnas</a> – kiire avarii toruabi Tallinna kesklinna piirkonnas</li>
            <li><a href="/toruabi-viimsi" class="text-emergency-red hover:underline font-semibold">Toruabi Viimsis</a> – professionaalne avarii toruabi Viimsi piirkonnas</li>
          </ul>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Районы обслуживания торуаби в Пирита</h2>
        <p class="text-gray-700 mb-4">Мы обслуживаем все районы Пирита, включая:</p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Пирита</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Пирита</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Меривялья</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Меривялья</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Клоостриметса</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Клоостриметса</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Иру</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Иру</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Мяхе</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Мяхе</p>
          </div>
