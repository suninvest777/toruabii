---
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import DistrictCrossLinks from '../components/DistrictCrossLinks.astro';
import FooterLegal from '../components/FooterLegal.astro';
import CallStripCta from '../components/CallStripCta.astro';
import { ruPath } from '../utils/i18n-paths';
import { serviceLandingBreadcrumbJsonLd } from '../utils/district-tallinn-jsonld';
import { serviceLandingSeo } from '../data/seo-keywords';

const siteUrl = 'https://toruabii.ee';
const pagePath = '/toruabi-rasvapuuduri-puhastus';
const landing = serviceLandingSeo['rasvapuuduri-puhastus'];

const phoneNumber = '+372 5633 3332';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = Astro.url.searchParams.get('lang') === 'ru' ? 'ru' : 'et';

const titleEt = landing.titleEt;
const descEt = landing.descriptionEt;
const titleRu = landing.titleRu;
const descRu = landing.descriptionRu;

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const faqEt = [
  {
    q: 'Kui sageli peaks rasvapüüdurit toruabi kaudu puhastama?',
    a: 'Sagedus sõltub köögi koormusest: toitlustuses soovitatakse sageli 1–3 kuu tagant, väiksemas majapidamises harvem. Toruabi annab nõu pärast mahuti ülevaatust.',
  },
  {
    q: 'Mis juhtub, kui rasvapüüdurit ei puhasta?',
    a: 'Rasv ja tahkained ummistavad väljalaske ja harud, suureneb tagasivoolu oht ja ebameeldiv lõhn. Toruabi aitab ennetada kallid remondid ja katkestused.',
  },
  {
    q: 'Kas rasvapüüduri toruabi sisaldab ka trasside puhastust?',
    a: 'Jah, sageli kombineerime rasvapüüduri tühjendamise või puhastamisega survepesu või mehaanilist puhastust ühendavatel lõikudel. Täpne töö ulatus fikseeritakse objektil.',
  },
  {
    q: 'Millal valida toruabi rasvapüüduri asemel kohe kanalisatsiooni survepesu?',
    a: 'Rasvapüüdur on esimene tõke köögi rasvale. Kui probleem on sügavamal trassis, võib toruabi lisaks teostada survepesu – vaata lehte Toruabi kanalisatsiooni survepesu.',
  },
  {
    q: 'Kas toruabi rasvapüüduri tööd tehakse ka nädalavahetusel?',
    a: 'Toitlustuse puhul on graafik sageli paindlik; täpne aeg kokkuleppel. Kiireloomulised üleujutused ja avariid lahendatakse ööpäevaringselt – vt toruabi avarii väljakutse.',
  },
];

const faqRu = [
  {
    q: 'Как часто чистить жироуловитель с торуаби?',
    a: 'Зависит от нагрузки кухни: в HoReCa часто раз в 1–3 месяца, в малом доме реже. Торуаби подскажет после осмотра ёмкости.',
  },
  {
    q: 'Что будет, если не чистить жироуловитель?',
    a: 'Жир и отложения забивают выпуск и ветки, растёт риск засоров и запаха. Регулярный торуаби дешевле аварийного ремонта.',
  },
  {
    q: 'Входит ли в работу торуаби промывка трасс?',
    a: 'Да, часто сочетаем обслуживание жироуловителя с промывкой или механической прочисткой примыкающих участков. Объём согласуем на месте.',
  },
  {
    q: 'Когда нужна сразу гидродинамическая промывка, а не только жироуловитель?',
    a: 'Жироуловитель — первая линия защиты на кухне. Если засор глубже, торуаби добавляет промывку — см. страницу гидродинамической промывки канализации.',
  },
  {
    q: 'Можно ли заказать торуаби для жироуловителя в выходные?',
    a: 'Для объектов HoReCa график обычно согласуется отдельно. Срочные аварии — круглосуточно, см. аварийный выезд торуаби.',
  },
];

const faqForLd = currentLang === 'ru' ? faqRu : faqEt;
const crumbHomeName = currentLang === 'ru' ? 'Главная' : 'Avaleht';
const crumbServiceEt = 'Rasvapüüduri puhastus (toruabi)';
const crumbServiceRu = 'Очистка жироуловителя (торуаби)';
const crumbServiceName = currentLang === 'ru' ? crumbServiceRu : crumbServiceEt;
const pageCanonicalUrl = currentLang === 'ru' ? `${siteUrl}${ruPath(pagePath)}` : `${siteUrl}${pagePath}`;
const breadcrumbJsonLdOverride = serviceLandingBreadcrumbJsonLd(pagePath, currentLang, crumbServiceEt, crumbServiceRu);

const plumbingLd = {
  '@context': 'https://schema.org',
  '@type': 'PlumbingService',
  '@id': `${pageCanonicalUrl}#plumbing`,
  name: 'toruabii.ee – Toruabi rasvapüüduri puhastus',
  alternateName: 'Rasvapüüdurite hooldus Tallinnas',
  url: pageCanonicalUrl,
  logo: `${siteUrl}/photos/toruabii.webp`,
  image: `${siteUrl}/photos/maintoruabii.webp`,
  description: pageDescription,
  telephone: '+37256333332',
  priceRange: '€€',
  paymentAccepted: ['Cash', 'Credit Card', 'Bank Transfer'],
  currenciesAccepted: 'EUR',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Tallinn',
    addressRegion: 'Harjumaa',
    addressCountry: 'EE',
  },
  areaServed: [
    { '@type': 'City', name: 'Tallinn' },
    { '@type': 'AdministrativeArea', name: 'Harjumaa' },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Rasvapüüduri puhastus ja hooldus',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Rasvapüüduri puhastus',
          description: 'Rasvapüüdurite hooldus ja puhastus restoranides ning korterelamutes',
        },
      },
    ],
  },
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${pageCanonicalUrl}#faq`,
  url: pageCanonicalUrl,
  inLanguage: currentLang,
  mainEntity: faqForLd.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={pageCanonicalUrl}
  ogImage="https://toruabii.ee/photos/maintoruabii.webp"
  suppressPlumbingJsonLd
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(plumbingLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqLd)} />
  
  <header class="bg-trust-blue text-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <Breadcrumb
        items={[
          { name: crumbHomeName, url: currentLang === 'ru' ? siteUrl + '/ru' : siteUrl + '/' },
          { name: crumbServiceName, url: pageCanonicalUrl },
        ]}
        class="text-gray-300 mb-3"
      />
      {currentLang === 'ru' ? (
        <a href="/ru" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">← На главную</a>
      ) : (
        <a href="/" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">← Tagasi avalehele</a>
      )}
      <h1 class="text-4xl md:text-5xl font-bold mb-3">{currentLang === 'ru' ? landing.h1Ru : landing.h1Et}</h1>
      <p class="text-xl text-gray-200 mb-6">
        {currentLang === 'ru'
          ? 'Очистка жироуловителя — часть грамотного обслуживания торуаби: канализация остаётся проходимой, меньше запаха и риска внезапной остановки. Работаем с небольшими кухнями и крупными объектами HoReCa.'
          : 'Rasvapüüduri puhastus on osa korralikust toruabi hooldusest: hoiame köögi kanalisatsiooni avatud, vähendame lõhna ja väldime ootamatuid sulgemisi. Sobib nii väikestele köökidele kui suurtele toitlustus- ja tootmisobjektidele.'}
      </p>
      <a href={`tel:${phoneLink}`} class="inline-block bg-emergency-red hover:bg-red-700 text-white font-bold py-4 px-8 rounded-lg text-xl">
        <span data-lang="callNowFull">HELISTA KOHE</span>: {phoneNumber}
      </a>
    </div>
  </header>

  <main class="py-12 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto space-y-12">
      <CallStripCta variant="page" />

      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-4">Miks on rasvapüüduri toruabi kohustuslik HoReCa objektidel?</h2>
        <p class="text-gray-700 mb-4">
          Köögivaljad, praepannid ja nõudepesu suunavad kanalisatsiooni suure koguse rasva. Rasvapüüdur kogub osa sellest, kuid ilma toruabi hoolduseta täitub mahuti ja lõtvib kogu süsteemi. Professionaalne toruabi dokumenteerib töö ja annab soovitused järgmiseks hoolduskorraks.
        </p>
        <h3 class="text-xl font-semibold text-trust-blue mb-2">Toruabi rasvapüüduri töö etapid (ülevaade)</h3>
        <ol class="list-decimal list-inside text-gray-700 space-y-2">
          <li>Olukorra ja mahuti ligipääsetavuse hindamine</li>
          <li>Puhastus või tühjendamine vastavalt tüübile ja nõuetele</li>
          <li>Vajadusel trasside survepesu või ummistuse likvideerimine</li>
          <li>Nõuanne järgmise toruabi külastuse intervalli kohta</li>
        </ol>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-4">Почему жироуловитель важен для HoReCa и как помогает торуаби?</h2>
        <p class="text-gray-700 mb-4">
          Кухня постоянно отправляет в канализацию жир. Жироуловитель задерживает часть осадка, но без обслуживания торуаби переполняется. Мы фиксируем работы и рекомендуем интервал.
        </p>
        <h3 class="text-xl font-semibold text-trust-blue mb-2">Этапы работ торуаби (кратко)</h3>
        <ol class="list-decimal list-inside text-gray-700 space-y-2">
          <li>Осмотр и доступ к ёмкости</li>
          <li>Очистка или откачка по типу и нормам</li>
          <li>При необходимости промывка или устранение засора на ветках</li>
          <li>Рекомендация по следующему визиту торуаби</li>
        </ol>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-4">Seotud toruabi teenused ja materjalid</h2>
        <p class="text-gray-700 mb-4">
          Rasvapüüdurist edasi liikuvad probleemid lahendame sageli koos{' '}
          <a href="/toruabi-kanalisatsiooni-survepesu" class="text-trust-blue font-semibold hover:underline">toruabi kanalisatsiooni survepesuga</a> või{' '}
          <a href="/toruabi-ummistuste-likvideerimine" class="text-trust-blue font-semibold hover:underline">ummistuste likvideerimisega</a>. Korteriomanikule:{' '}
          <a href="/blog/kanalisatsiooni-ummistus-mida-teha" class="text-trust-blue font-semibold hover:underline">kanalisatsiooni ummistus – mida teha?</a>
        </p>
        <p class="text-gray-700">
          Kiireloomulised olukorrad:{' '}
          <a href="/toruabi-avariiline-valjakutse" class="text-emergency-red font-semibold hover:underline">toruabi avarii väljakutse</a>. Hinnad:{' '}
          <a href="/hinnakiri" class="text-trust-blue font-semibold hover:underline">hinnakiri</a>.
        </p>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-4">Связанные услуги торуаби</h2>
        <p class="text-gray-700 mb-4">
          После жироуловителя часто нужны{' '}
          <a href="/ru/toruabi-kanalisatsiooni-survepesu" class="text-trust-blue font-semibold hover:underline">гидродинамическая промывка</a> или{' '}
          <a href="/ru/toruabi-ummistuste-likvideerimine" class="text-trust-blue font-semibold hover:underline">устранение засоров</a>. Для квартир — статья:{' '}
          <a href="/ru/blog/kanalisatsiooni-ummistus-mida-teha" class="text-trust-blue font-semibold hover:underline">засор канализации: что делать?</a>
        </p>
        <p class="text-gray-700">
          Срочно:{' '}
          <a href="/ru/toruabi-avariiline-valjakutse" class="text-emergency-red font-semibold hover:underline">аварийный торуаби</a>. Цены:{' '}
          <a href="/ru/hinnakiri" class="text-trust-blue font-semibold hover:underline">прайс</a>.
        </p>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-2xl font-bold text-trust-blue mb-4">Korduma kippuvad küsimused – toruabi ja rasvapüüdur</h2>
        <div class="space-y-4">
          {faqEt.map((item) => (
            <details class="bg-gray-50 rounded-lg p-4">
              <summary class="font-bold text-trust-blue cursor-pointer">{item.q}</summary>
              <p class="text-gray-700 mt-2">{item.a}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-2xl font-bold text-trust-blue mb-4">Частые вопросы – торуаби и жироуловитель</h2>
        <div class="space-y-4">
          {faqRu.map((item) => (
            <details class="bg-gray-50 rounded-lg p-4">
              <summary class="font-bold text-trust-blue cursor-pointer">{item.q}</summary>
              <p class="text-gray-700 mt-2">{item.a}</p>
            </details>
          ))}
        </div>
      </section>

      <DistrictCrossLinks currentPath={pagePath} />

      <section class="bg-emergency-red text-white rounded-lg p-8 text-center">
        <h2 class="text-3xl font-bold mb-4 blog-et">Telli toruabi rasvapüüduri hoolduseks</h2>
        <h2 class="text-3xl font-bold mb-4 blog-ru">Закажите торуаби для обслуживания жироуловителя</h2>
        <p class="text-lg mb-6 blog-et">Toruabi Tallinnas ja Harjumaal – helista juba täna.</p>
        <p class="text-lg mb-6 blog-ru">Торуаби в Таллине и Харьюмаа — позвоните сегодня.</p>
        <a href={`tel:${phoneLink}`} class="inline-block bg-white text-emergency-red font-bold py-4 px-8 rounded-lg text-xl hover:bg-gray-100">
          <span data-lang="callNowFull">HELISTA KOHE</span>: {phoneNumber}
        </a>
      </section>
    </div>
  </main>

  <footer class="bg-trust-blue text-white py-8 px-4 text-center">
    <p class="mb-2"><a href={`tel:${phoneLink}`} class="text-xl font-bold text-emergency-red">{phoneNumber}</a></p>
    <p class="text-xs text-gray-400 mb-2 max-w-xl mx-auto blog-et">
      Teenuspiirkond: Tallinn ja Harjumaa · info@toruabii.ee · +372 5633 3332
    </p>
    <p class="text-xs text-gray-400 mb-2 max-w-xl mx-auto blog-ru">
      Зона обслуживания: Таллин и Харьюмаа · info@toruabii.ee · +372 5633 3332
    </p>
    <FooterLegal variant="bilingual" />
    <p class="text-sm text-gray-300">© 2026 toruabii.ee - Kõik õigused kaitstud</p>
  </footer>

  <StickyCTA />
</BaseLayout>
