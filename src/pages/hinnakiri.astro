---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import FooterLegal from '../components/FooterLegal.astro';
import NavGoogleReviewLink from '../components/NavGoogleReviewLink.astro';
import CallStripCta from '../components/CallStripCta.astro';
import { homeHref, ruPath } from '../utils/i18n-paths';
import { seoInnerDescription, seoInnerTitle } from '../data/seo-keywords';

const siteUrl = 'https://toruabii.ee';

const phoneNumber = '+372 5181 112';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = Astro.url.searchParams.get('lang') === 'ru' ? 'ru' : 'et';

const titleEt = seoInnerTitle('Toruabi hinnakiri', 'et');
const descEt = seoInnerDescription({
  pageLabel: 'Toruabi hinnad ja hinnakiri',
  lang: 'et',
  extra: 'Väljakutse, ummistuste likvideerimine. −50% pärast esimest tundi kuni kuu lõpuni.',
});
const titleRu = seoInnerTitle('Торуаби цены', 'ru');
const descRu = seoInnerDescription({
  pageLabel: 'Прайс торуаби',
  lang: 'ru',
  extra: 'Выезд, прочистка. −50% после первого часа до конца месяца.',
});

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const hinnakiriPath = '/hinnakiri';
const canonicalUrl =
  currentLang === 'ru' ? `${siteUrl}${ruPath(hinnakiriPath)}` : `${siteUrl}${hinnakiriPath}`;
const crumbHomeUrl = currentLang === 'ru' ? `${siteUrl}/ru` : `${siteUrl}/`;
---

<BaseLayout 
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={canonicalUrl}
  ogImage="https://toruabii.ee/photos/toruabii.webp"
  keywords={currentLang === 'ru' ? "торуаби, торуаби цены, торуаби Таллинн, аварийный сантехник цены, сантехнические работы" : "toruabi, toruabi hinnad, toruabi Tallinnas, avarii toruabi hinnad, toruabi hind"}
>
<!-- Header -->
  <header class="bg-trust-blue text-white py-6 px-4 pt-4 md:pt-6">
    <div class="max-w-6xl mx-auto">
      <Breadcrumb
        items={[
          { name: currentLang === 'ru' ? 'Главная' : 'Avaleht', url: crumbHomeUrl },
          { name: currentLang === 'ru' ? 'Цены' : 'Hinnakiri', url: canonicalUrl },
        ]}
        class="text-gray-300 mb-3"
      />
      <a href={homeHref(currentLang)} class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold" data-lang="backToHome">← Tagasi avalehele</a>
      <h1 class="text-4xl md:text-5xl font-bold mb-2" data-lang="pricingPageTitle">Konkurentsivõimelised hinnad kvaliteetse sanitaartehnilise töö eest</h1>
      <p class="text-gray-200" data-lang="pricingPageSubtitle">toruabii - Avariiline santehnik Harjumaal 24/7</p>
      <div class="mt-6 max-w-xl mx-auto rounded-2xl bg-black/25 p-3 ring-1 ring-white/20">
        <CallStripCta variant="page" />
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="py-12 px-4 bg-gray-50 min-h-screen">
    <div class="max-w-6xl mx-auto">
      
      <!-- Pricing Info Section -->
      <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
        <h2 class="text-2xl font-bold text-trust-blue mb-4" data-lang="pricingInfoTitle">Ценообразование</h2>
        <ul class="space-y-2 text-gray-700">
          <li data-lang="pricingInfo1">Минимальная плата за вызов – это цена первого часа работы! Далее с шагом в 10 минут.</li>
          <li data-lang="pricingInfo2">Работы, которых нет в приведённом списке, выполняются соответственно калькуляции, уточните у диспетчера, либо на месте.</li>
          <li data-lang="pricingInfo3">При выполнении объёмных работ цена договорная. Ориентировочную стоимость уточнить у диспетчера.</li>
        </ul>
      </div>

      <!-- Payment Methods Section -->
      <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
        <h2 class="text-2xl font-bold text-trust-blue mb-4" data-lang="paymentMethodsTitle">Способы оплаты</h2>
        <p class="text-gray-700" data-lang="paymentMethodsText">Принимаем как наличные, так и оплату картой через терминал, фирмы оплачивают услугу по счету</p>
      </div>

      <!-- Documentation Section -->
      <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
        <h2 class="text-2xl font-bold text-trust-blue mb-4" data-lang="documentationTitle">Документация, чеки, акты</h2>
        <p class="text-gray-700" data-lang="documentationText">После каждого заказа мы выписываем квитанцию, при оплате картой чек. Так же составляем АКТ для страховой компании.</p>
      </div>

      <!-- Pricing Table -->
      <div class="bg-white rounded-lg shadow-lg overflow-hidden mb-8">
        <div class="bg-trust-blue text-white px-6 py-4">
          <h2 class="text-2xl font-bold" data-lang="plannedWork">Planeetitud tööd</h2>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-100">
              <tr>
                <th class="px-6 py-4 text-left text-sm font-bold text-trust-blue" data-lang="service">Teenus</th>
                <th class="px-6 py-4 text-right text-sm font-bold text-trust-blue" data-lang="price">Hind</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService1">Санитарно-технические работы</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 45€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService3">Сварка PEM-труб</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 48€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService4">Инспекция труб камерой</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">75€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService5">Промыв отопительной системы</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 25€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService6">Чистка теплообменников</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 25€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService7">Опрессовка трубопроводов</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 50€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService8">Опрессовка отопительной системы и теплоузла</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 45€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService9">Мойка внутридомовых труб горячей водой под давлением до 75 бар</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">250€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService10">Гидродинамическая промывка канализационных систем</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 200€</td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService11">Очистка жироуловителей и пескоуловителей</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">294€ <span data-lang="pricePerM3">/ 1М3</span></td>
              </tr>
              <tr class="hover:bg-gray-50 bg-yellow-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService12">К цене добавляется стоимость утилизации</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 50€ <span data-lang="pricePerM3">/ 1М3</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService13">Размораживание пластмассовых труб</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 75€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService14">Размораживание металлических труб</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue"><span data-lang="priceFrom">От</span> 75€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50 bg-blue-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService15">Тариф за пределы Таллинна</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">0,50€ <span data-lang="pricePerKm">/ 1km</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService16">Вакуумная прочистка</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">60,40€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService17">Прочистка засоров Rothenberger 16 мм</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">100,80€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="priceService18">Прочистка засоров Rothenberger 22 мм</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">161,29€ <span data-lang="pricePerHour">/ час</span></td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div class="bg-gray-100 px-6 py-4 border-t">
          <p class="text-sm text-gray-700">
            <strong data-lang="vatNote">Hinnale lisandub käibemaks 24%</strong>
          </p>
        </div>
      </div>

      <!-- High Pressure Machine Section -->
      <div class="bg-white rounded-lg shadow-lg overflow-hidden mb-8">
        <div class="bg-trust-blue text-white px-6 py-4">
          <h2 class="text-2xl font-bold" data-lang="highPressureMachineTitle">Вызов прочистной машины высокого давления</h2>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-100">
              <tr>
                <th class="px-6 py-4 text-left text-sm font-bold text-trust-blue" data-lang="service">Услуга</th>
                <th class="px-6 py-4 text-right text-sm font-bold text-trust-blue" data-lang="price">Цена</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="highPressureMachineWeekday">Час работы ПН-ПТ(8:00-17:00)</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">175€<span data-lang="pricePerHour">/час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="highPressureMachineWeekend">Час работы ПН-ВС(17:00-00:00)</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">250€<span data-lang="pricePerHour">/час</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="highPressureMachineOutside">Выезд за пределы Таллинна(туда-обратно)</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">2€<span data-lang="pricePerKm">/км</span></td>
              </tr>
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-gray-700" data-lang="highPressureMachineMinPayment">Минимальная оплата</td>
                <td class="px-6 py-4 text-right font-bold text-trust-blue">2ч</td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div class="bg-gray-100 px-6 py-4 border-t">
          <p class="text-sm text-gray-700" data-lang="highPressureMachineNote">К ценам за откачку выгребных ям и промывку канализационных трасс и колодцев добавляется стоимость за транспортные расходы, забор воды, стоимость утилизации сточных вод/жира/песка</p>
        </div>
      </div>

      <!-- Why Choose Section -->
      <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
        <h2 class="text-2xl font-bold text-trust-blue mb-4" data-lang="whyChooseTitle">Почему выбрать Toruabii?</h2>
        <p class="text-gray-700 mb-4" data-lang="whyChooseIntro">Мы гарантируем высокое качество и надежность во всех наших работах.</p>
        <ul class="space-y-3 text-gray-700">
          <li class="flex items-start">
            <span class="text-emergency-red mr-2">✓</span>
            <span data-lang="whyChoose1">Четкое планирование процессов и быстрое реагирование</span>
          </li>
          <li class="flex items-start">
            <span class="text-emergency-red mr-2">✓</span>
            <span data-lang="whyChoose2">Использование современного оборудования и технологий</span>
          </li>
          <li class="flex items-start">
            <span class="text-emergency-red mr-2">✓</span>
            <span data-lang="whyChoose3">Использование сертифицированных и долговечных материалов</span>
          </li>
          <li class="flex items-start">
            <span class="text-emergency-red mr-2">✓</span>
            <span data-lang="whyChoose4">Профессионализм и опыт наших сотрудников</span>
          </li>
        </ul>
      </div>

      <!-- Warning Section -->
      <div class="bg-caution-yellow/20 border-2 border-caution-yellow rounded-lg p-6 mb-8">
        <h2 class="text-xl font-bold text-trust-blue mb-4" data-lang="warningTitle">ВНИМАНИЕ!</h2>
        <ul class="space-y-2 text-gray-700">
          <li data-lang="warningText">Гарантия не распространяется на устранение засоров.</li>
          <li data-lang="warningText2">Мы выполняем как мелкие, так и крупные аварийные работы, независимо от сложности.</li>
        </ul>
      </div>

      <!-- Districts Section -->
      <div class="bg-white rounded-lg shadow-lg p-6 mb-8">
        <h2 class="text-2xl font-bold text-trust-blue mb-4 blog-et">Toruabi piirkondades</h2>
        <h2 class="text-2xl font-bold text-trust-blue mb-4 blog-ru">Торуаби в районах</h2>
        <p class="text-gray-700 mb-4 blog-et">Me pakume toruabi teenuseid kõigis Tallinna piirkondades. Vaadake hinnakirju konkreetsetele piirkondadele:</p>
        <p class="text-gray-700 mb-4 blog-ru">Мы предоставляем услуги торуаби во всех районах Таллинна. Посмотрите информацию по конкретным районам:</p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="/toruabi-lasnamae" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-et">Toruabi Lasnamäes</a>
          <a href="/toruabi-lasnamae" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-ru">Торуаби в Ласнамяэ</a>
          <a href="/toruabi-mustamae" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-et">Toruabi Mustamäel</a>
          <a href="/toruabi-mustamae" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-ru">Торуаби в Мустамяэ</a>
          <a href="/toruabi-kesklinn" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-et">Toruabi Kesklinnas</a>
          <a href="/toruabi-kesklinn" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-ru">Торуаби в центре</a>
          <a href="/toruabi-pirita" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-et">Toruabi Piritas</a>
          <a href="/toruabi-pirita" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-ru">Торуаби в Пирита</a>
          <a href="/toruabi-viimsi" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-et">Toruabi Viimsis</a>
          <a href="/toruabi-viimsi" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors blog-ru">Торуаби в Виймси</a>
        </div>
      </div>

      <!-- Related services -->
      <div class="bg-white rounded-lg shadow-lg p-6 mb-8 blog-et">
        <h2 class="text-2xl font-bold text-trust-blue mb-4">Toruabi teenused ja hinnad</h2>
        <p class="text-gray-700">
          Kanalisatsiooni ummistuste puhul vaata eraldi lehte{' '}
          <a href="/toruabi-ummistuste-likvideerimine" class="text-emergency-red font-semibold hover:underline">ummistuste likvideerimine</a>
          {' '}või telli otse{' '}
          <a href="/toruabi-ummistuste-likvideerimine" class="text-trust-blue font-semibold hover:underline">toruabi ummistus</a>
          {' '}teenus – väljasõit 0 €, reageerimine 30–60 min. Korduvate probleemide korral sobib ka{' '}
          <a href="/toruabi-kanalisatsiooni-survepesu" class="text-trust-blue font-semibold hover:underline">kanalisatsiooni survepesu</a>.
        </p>
      </div>
      <div class="bg-white rounded-lg shadow-lg p-6 mb-8 blog-ru">
        <h2 class="text-2xl font-bold text-trust-blue mb-4">Услуги торуаби и цены</h2>
        <p class="text-gray-700">
          При засоре канализации — страница{' '}
          <a href="/ru/toruabi-ummistuste-likvideerimine" class="text-emergency-red font-semibold hover:underline">устранение засоров</a>
          {' '}или заказ{' '}
          <a href="/ru/toruabi-ummistuste-likvideerimine" class="text-trust-blue font-semibold hover:underline">торуаби при засоре</a>
          {' '}— выезд 0 €, приезд 30–60 мин. При повторных засорах —{' '}
          <a href="/ru/toruabi-kanalisatsiooni-survepesu" class="text-trust-blue font-semibold hover:underline">промывка канализации</a>.
        </p>
      </div>

      <!-- CTA Section -->
      <div class="bg-emergency-red text-white rounded-lg p-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-4" data-lang="needEstimate">Нужна более точная оценка?</h2>
        <p class="text-lg mb-6" data-lang="callForPrice">Позвоните нам и мы договоримся о цене!</p>
        <a
          href={`tel:${phoneLink}`}
          class="inline-block bg-white text-emergency-red font-bold py-4 px-8 rounded-lg text-xl hover:bg-gray-100 transition-colors min-h-[56px] flex items-center justify-center"
        >
          <span data-lang="callNowFull">ПОЗВОНИТЬ СЕЙЧАС</span>: {phoneNumber}
        </a>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-trust-blue text-white py-8 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <p class="mb-2">
        <a href={`tel:${phoneLink}`} class="text-xl font-bold text-emergency-red hover:text-red-400">
          {phoneNumber}
        </a>
      </p>
      <!-- Districts Links -->
      <div class="mb-4 pt-4 border-t border-white/20">
        <div class="text-sm font-bold mb-3" data-lang="serviceAreas">Toruabi piirkondades:</div>
        <div class="flex flex-wrap justify-center gap-3 text-xs">
          <a href="/toruabi-lasnamae" class="text-white/80 hover:text-white hover:underline transition-colors">Lasnamäe</a>
          <a href="/toruabi-mustamae" class="text-white/80 hover:text-white hover:underline transition-colors">Mustamäe</a>
          <a href="/toruabi-kesklinn" class="text-white/80 hover:text-white hover:underline transition-colors">Kesklinn</a>
          <a href="/toruabi-pirita" class="text-white/80 hover:text-white hover:underline transition-colors">Pirita</a>
          <a href="/toruabi-viimsi" class="text-white/80 hover:text-white hover:underline transition-colors">Viimsi</a>
        </div>
      </div>
