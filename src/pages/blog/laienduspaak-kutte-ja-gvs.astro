---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { ruPath } from '../../utils/i18n-paths';
import BlogPostingSchema from '../../components/BlogPostingSchema.astro';
import { sitemapEntries } from '../../data/sitemap-entries';
import { blogArticleBreadcrumbMeta } from '../../data/blog-article-breadcrumbs';
import { blogArticleBreadcrumbOverride } from '../../utils/seo-jsonld';
import { pageLang } from '../../utils/page-lang';
import LangOnly from '../../components/LangOnly.astro';

const phoneNumber = '+372 5633 3332';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = pageLang(Astro.url);

const titleEt =
  'Laienduspaak küttesüsteemi ja soojavee jaoks Tallinnas – toruabi, paigaldus ja remont 24/7 | toruabii.ee';
const descEt =
  'Laienduspaak küttesüsteemi ja soojaveevarustuse jaoks Tallinnas: toruabi 24/7, laienduspaagi paigaldus, remont ja hooldus. Küttesüsteemi laienduspaak, soojaveevarustuse laienduspaak. Professionaalne laienduspaagi torumees Lasnamäes, Mustamäel, Kesklinnas, Piritas, Viimsis. Laienduspaagi valik, rõhk, maht.';
const titleRu =
  'Расширительный бак для отопления и ГВС – отличия и выбор | toruabii.ee';
const descRu =
  'Расширительный бак является важным элементом систем отопления и горячего водоснабжения. Он предназначен для компенсации теплового расширения теплоносителя и поддержания стабильного давления в системе. Рассказываем об отличиях баков для отопления и ГВС в Таллине и Харьюмаа.';

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const articlePath = '/blog/laienduspaak-kutte-ja-gvs';
const articleDatePublished = sitemapEntries.find((e) => e.path === articlePath)?.lastmod ?? '2026-01-01';
const siteOrigin = 'https://toruabii.ee';
const canonicalUrl = currentLang === 'ru' ? `${siteOrigin}${ruPath(articlePath)}` : `${siteOrigin}${articlePath}`;
const articleCrumb = blogArticleBreadcrumbMeta['laienduspaak-kutte-ja-gvs'];
const breadcrumbJsonLdOverride = blogArticleBreadcrumbOverride(
  articlePath,
  currentLang,
  articleCrumb.category,
  articleCrumb.crumbNameEt,
  articleCrumb.crumbNameRu
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={canonicalUrl}
  ogImage="https://toruabii.ee/photos/sistema-otoplenija-connectors-liking.webp"
  ogType="article"
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <BlogPostingSchema
    slot="head"
    lang={currentLang}
    headlineEt={titleEt}
    headlineRu={titleRu}
    descriptionEt={descEt}
    descriptionRu={descRu}
    canonicalPath={articlePath}
    datePublished={articleDatePublished}
    imageUrl="https://toruabii.ee/photos/sistema-otoplenija-connectors-liking.webp"
  />
  <script
    slot="head"
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': canonicalUrl + '#faq',
    url: canonicalUrl,
    inLanguage: currentLang,
    mainEntity: [
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'В чем разница между расширительным баком для отопления и ГВС?' : 'Mis vahe on küttesüsteemi ja soojaveevarustuse laienduspaagil?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Расширительный бак для отопления предназначен для компенсации расширения теплоносителя в системе отопления. Расширительный бак для ГВС предназначен для компенсации расширения горячей воды в системе горячего водоснабжения и должен соответствовать контакту с питьевой водой.'
            : 'Küttesüsteemi laienduspaak on mõeldud kompenseerima soojusülekande paisumist küttesüsteemis. Soojaveevarustuse laienduspaak on mõeldud kompenseerima vee paisumist soojaveevarustuse süsteemis ja peab vastama joogiveega kokkupuute nõuetele.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Сколько стоит установка расширительного бака в Таллине?' : 'Kui palju maksab laienduspaagi paigaldus Tallinnas?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Стоимость установки расширительного бака в Таллине зависит от объема бака и сложности системы. Небольшой расширительный бак (10-50 литров) может стоить 200-500€, большой (100+ литров) 500-1500€.'
            : 'Laienduspaagi paigalduse hind Tallinnas sõltub paagi mahust ja süsteemi keerukusest. Väiksem laienduspaak (10-50 liitrit) võib maksta 200-500€, suurem (100+ liitrit) 500-1500€.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Когда нужен расширительный бак?' : 'Millal on vaja laienduspaaki?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Расширительный бак необходим для всех закрытых систем отопления и систем горячего водоснабжения. Он компенсирует расширение воды при нагревании и обеспечивает стабильное давление в системе.'
            : 'Laienduspaak on vajalik kõigile suletud küttesüsteemidele ja soojaveevarustuse süsteemidele. See kompenseerib vee paisumist kuumutamisel ja tagab stabiilse rõhu süsteemis.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Какого размера нужен расширительный бак?' : 'Kui suur laienduspaak on vajalik?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Размер расширительного бака зависит от объема системы. Общее правило: примерно 10% от объема системы. Например, для системы объемом 100 литров нужно около 10 литров расширительного бака.'
            : 'Laienduspaagi suurus sõltub süsteemi mahust. Üldreegel: umbes 10% süsteemi mahust. Näiteks 100-liitrise süsteemi jaoks vajate umbes 10-liitrist laienduspaaki.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Требует ли расширительный бак обслуживания?' : 'Kas laienduspaak nõuab hooldust?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Расширительный бак требует минимального обслуживания. Рекомендуем проверять давление и состояние мембраны раз в год. Если расширительный бак правильно установлен, он может работать годами без особого обслуживания.'
            : 'Laienduspaak nõuab minimaalset hooldust. Soovitame kontrollida rõhku ja membraani seisundit kord aastas. Kui laienduspaak on õigesti paigaldatud, võib see töötada aastaid ilma erilise hoolduseta.',
        },
      },
    ],
  })}
/>

<!-- Estonian header -->
  <LangOnly lang="et" activeLang={currentLang}>
<header class="bg-trust-blue text-white py-6 px-4">
    <div class="max-w-5xl mx-auto">
      <nav class="text-sm text-gray-300 mb-3" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1">
          <li><a href="/" class="hover:text-white">Avaleht</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/blog" class="hover:text-white">Blogi</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/blog/kategoria/kuttesusteem" class="hover:text-white">Küttesüsteem</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-200">Laienduspaak</li>
        </ol>
      </nav>
      <a href="/blog/kategoria/kuttesusteem" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">
        ← Tagasi küttesüsteemi artiklite juurde
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">
        Laienduspaak küttesüsteemi ja soojavee jaoks Tallinnas: toruabi, paigaldus ja remont 24/7
      </h1>
      <p class="text-gray-200 max-w-2xl">
        Vajate laienduspaagi paigaldust, remonti või hooldust Tallinnas? Meie professionaalne torumees pakub laienduspaagi toruabi 24/7 Lasnamäes, Mustamäel, Kesklinnas, Piritas, Viimsis ja kõigis Tallinna piirkondades. Laienduspaak koosneb hermeetilisest mahutist, mis on täidetud vedelikuga, ja elastsest membraanist, mis eraldab vedeliku ja õhu. Kuumutamisel paisub soojuskandja ja täidab membraani taga olevat ruumi, mis kompenseerib rõhu tõusu süsteemis.
      </p>
      <p class="text-sm text-gray-300 mt-3">
        Avaldatud: {new Date('2023-10-03').toLocaleDateString('et-EE', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </div>
  </header>
</LangOnly>

  <!-- Russian header -->
  <LangOnly lang="ru" activeLang={currentLang}>
<header class="bg-trust-blue text-white py-6 px-4">
    <div class="max-w-5xl mx-auto">
      <nav class="text-sm text-gray-300 mb-3" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1">
          <li><a href="/ru" class="hover:text-white">Главная</a></li>
          <li aria-hidden="true">›</li>
