---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import LangOnly from '../../components/LangOnly.astro';
import { pageLang } from '../../utils/page-lang';
import { ruPath } from '../../utils/i18n-paths';
import BlogPostingSchema from '../../components/BlogPostingSchema.astro';
import { sitemapEntries } from '../../data/sitemap-entries';
import { blogArticleBreadcrumbMeta } from '../../data/blog-article-breadcrumbs';
import { blogArticleBreadcrumbOverride } from '../../utils/seo-jsonld';

const phoneNumber = '+372 5181 112';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = pageLang(Astro.url);

const titleEt =
  'Küttesüsteemi hooldus ja radiaatorite tühjendamine Tallinnas – kuidas ja millal? | toruabii.ee';
const descEt =
  'Praktiline juhend radiaatorite tühjendamise kohta: miks see on oluline, kui tihti seda teha, kuidas õigesti vett radiaatoritest välja lasta ja millal kutsuda professionaalne küttesüsteemi toruabi Tallinnas ja Harjumaal.';
const titleRu =
  'Обслуживание системы отопления и слив воды с радиаторов в Таллине | toruabii.ee';
const descRu =
  'Практическое руководство по сливу воды с радиаторов: зачем это нужно, как часто делать, как правильно слить воду и когда вызывать профессионального сантехника по отоплению в Таллине и Харьюмаа.';

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const articlePath = '/blog/kuttesusteemi-hooldus-radiaatorite-tyhjendamine';
const articleDatePublished = sitemapEntries.find((e) => e.path === articlePath)?.lastmod ?? '2026-01-01';
const siteOrigin = 'https://toruabii.ee';
const canonicalUrl = currentLang === 'ru' ? `${siteOrigin}${ruPath(articlePath)}` : `${siteOrigin}${articlePath}`;
const articleCrumb = blogArticleBreadcrumbMeta['kuttesusteemi-hooldus-radiaatorite-tyhjendamine'];
const breadcrumbJsonLdOverride = blogArticleBreadcrumbOverride(
  articlePath,
  currentLang,
  articleCrumb.category,
  articleCrumb.crumbNameEt,
  articleCrumb.crumbNameRu
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={canonicalUrl}
  ogImage="https://toruabii.ee/photos/otoplenije-batarei-liking.webp"
  ogType="article"
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <BlogPostingSchema
    slot="head"
    lang={currentLang}
    headlineEt={titleEt}
    headlineRu={titleRu}
    descriptionEt={descEt}
    descriptionRu={descRu}
    canonicalPath={articlePath}
    datePublished={articleDatePublished}
    imageUrl="https://toruabii.ee/photos/otoplenije-batarei-liking.webp"
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'HowTo',
      '@id': canonicalUrl + '#howto',
      name: currentLang === 'ru'
        ? 'Как правильно слить воду с радиаторов отопления'
        : 'Kuidas õigesti radiaatoreid tühjendada',
      description: currentLang === 'ru'
        ? 'Пошаговая инструкция по сливу воды с радиаторов отопления: как безопасно удалить воздух и воду из системы отопления.'
        : 'Samm-sammult juhend radiaatorite tühjendamiseks: kuidas ohutult eemaldada õhk ja vesi küttesüsteemist.',
      image: 'https://toruabii.ee/photos/otoplenije-batarei-liking.webp',
      totalTime: 'PT30M',
      estimatedCost: {
        '@type': 'MonetaryAmount',
        currency: 'EUR',
        value: '0',
      },
      tool: [
        {
          '@type': 'HowToTool',
          name: currentLang === 'ru' ? 'Ключ для воздушного клапана' : 'Õhuklapi võti',
        },
        {
          '@type': 'HowToTool',
          name: currentLang === 'ru' ? 'Емкость для воды' : 'Vee nõu',
        },
      ],
      step: [
        {
          '@type': 'HowToStep',
          position: 1,
          name: currentLang === 'ru' ? 'Выключите систему отопления' : 'Lülitage küttesüsteem välja',
          text: currentLang === 'ru'
            ? 'Выключите систему отопления и подождите, пока радиаторы остынут. Это обычно занимает несколько часов.'
            : 'Lülitage küttesüsteem välja ja oodake, kuni radiaatorid jahtuvad. See võtab tavaliselt mitu tundi.',
          image: 'https://toruabii.ee/photos/otoplenije-batarei-liking.webp',
        },
        {
          '@type': 'HowToStep',
          position: 2,
          name: currentLang === 'ru' ? 'Найдите воздушный клапан' : 'Leidke õhuklapp',
          text: currentLang === 'ru'
            ? 'Найдите воздушный клапан в верхней части радиатора, обычно на противоположной стороне от подключения к сети.'
            : 'Leidke õhuklapp radiaatori ülaosas, tavaliselt vastasküljel võrguühendusest.',
          image: 'https://toruabii.ee/photos/otoplenije-batarei-liking.webp',
        },
        {
          '@type': 'HowToStep',
          position: 3,
          name: currentLang === 'ru' ? 'Подготовьте емкость' : 'Valmistage ette nõu',
          text: currentLang === 'ru'
            ? 'Поместите емкость или пакет под воздушный клапан, чтобы собрать воду и воздух.'
            : 'Asetage nõu või kott õhuklapi alla, et kinni püüda vett ja õhku.',
          image: 'https://toruabii.ee/photos/otoplenije-batarei-liking.webp',
        },
        {
          '@type': 'HowToStep',
          position: 4,
          name: currentLang === 'ru' ? 'Откройте воздушный клапан' : 'Avage õhuklapp',
          text: currentLang === 'ru'
            ? 'Используйте специальный ключ или отвертку. Откройте медленно и позвольте воздуху и воде выйти.'
            : 'Kasutage spetsiaalset võtit või kruvikeeretit. Avage aeglaselt ja laske õhul ja veel välja tulla.',
          image: 'https://toruabii.ee/photos/otoplenije-batarei-liking.webp',
        },
        {
          '@type': 'HowToStep',
          position: 5,
          name: currentLang === 'ru' ? 'Дождитесь прекращения потока воды' : 'Oodake, kuni vesi lakkab voolamast',
          text: currentLang === 'ru'
            ? 'Когда вода перестанет течь, воздух удален. Закройте воздушный клапан.'
            : 'Kui vesi lakkab voolamast, on õhk eemaldatud. Sulgege õhuklapp.',
          image: 'https://toruabii.ee/photos/otoplenije-batarei-liking.webp',
        },
        {
          '@type': 'HowToStep',
          position: 6,
          name: currentLang === 'ru' ? 'Проверьте давление' : 'Kontrollige rõhku',
          text: currentLang === 'ru'
            ? 'После удаления воздуха проверьте давление в системе отопления и при необходимости добавьте воды.'
            : 'Pärast õhu eemaldamist kontrollige küttesüsteemi rõhku ja vajadusel lisage vett.',
          image: 'https://toruabii.ee/photos/otoplenije-batarei-liking.webp',
        },
      ],
    })}
  />
<!-- Estonian version -->
  <header class="bg-trust-blue text-white py-6 px-4">
    <div class="max-w-5xl mx-auto">
      <nav class="text-sm text-gray-300 mb-3" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1">
          <li>
            <a href="/" class="hover:text-white">Avaleht</a>
          </li>
          <li aria-hidden="true">›</li>
          <li>
            <a href="/blog" class="hover:text-white">Blogi</a>
          </li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-200">
            Küttesüsteemi hooldus ja radiaatorite tühjendamine
          </li>
        </ol>
      </nav>
      <a
        href="/blog"
        class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold"
      >
        ← Tagasi blogisse
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">
        Küttesüsteemi hooldus ja radiaatorite tühjendamine Tallinnas: kuidas ja millal?
      </h1>
      <p class="text-gray-200 max-w-2xl">
        Õigeaegne radiaatorite tühjendamine ja hooldus pikendab küttesüsteemi eluiga,
        parandab soojusülekannet ja vähendab energiakulusid. Selgitame, kuidas seda
        õigesti teha ja millal kutsuda professionaalne küttesüsteemi toruabi.
      </p>
      <p class="text-sm text-gray-300 mt-3">
        Avaldatud:{' '}
        {new Date('2026-03-06').toLocaleDateString('et-EE', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </p>
    </div>
  </header>

  <header class="bg-trust-blue text-white py-6 px-4">
    <div class="max-w-5xl mx-auto">
      <nav class="text-sm text-gray-300 mb-3" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1">
          <li>
            <a href="/ru" class="hover:text-white">Главная</a>
          </li>
          <li aria-hidden="true">›</li>
          <li>
            <a href="/ru/blog" class="hover:text-white">Блог</a>
          </li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-200">
            Обслуживание системы отопления и слив воды с радиаторов
          </li>
        </ol>
      </nav>
      <a
        href="/ru/blog"
        class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold"
      >
        ← Назад в блог
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">
        Обслуживание системы отопления и слив воды с радиаторов в Таллине: как и когда?
      </h1>
      <p class="text-gray-200 max-w-2xl">
        Своевременный слив воды с радиаторов и обслуживание системы отопления продлевает
        срок службы, улучшает теплоотдачу и снижает расходы на отопление. Рассказываем,
        как это делать правильно и когда вызывать профессионального сантехника.
      </p>
      <p class="text-sm text-gray-300 mt-3">
        Опубликовано:{' '}
        {new Date('2026-03-06').toLocaleDateString('ru-RU', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </p>
    </div>
  </header>

  <main class="py-12 px-4 bg-gray-50 min-h-screen">
    <LangOnly lang="et" activeLang={currentLang}>
<article class="max-w-5xl mx-auto bg-white rounded-lg shadow-lg p-6 md:p-8">
      <figure class="mb-6">
        <img
          src="/photos/otoplenije-batarei-liking.webp"
          alt="Küttesüsteemi hooldus ja radiaatorite tühjendamine Tallinnas – professionaalne torumees töötab radiaatoritega"
          class="w-full h-64 md:h-80 object-cover rounded-lg"
          loading="eager"
          width="1000"
          height="600"
        />
      </figure>
      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          1. Miks on oluline regulaarselt radiaatoreid tühjendada?
        </h2>
        <p class="text-gray-700 mb-3">
          Radiaatorite tühjendamine ja küttesüsteemi hooldus on oluline mitmel põhjusel:
        </p>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li>
            <strong>Õhu eemaldamine</strong> – aja jooksul koguneb radiaatoritesse õhku,
            mis halvendab soojusülekannet ja võib põhjustada "plärisevaid" helisid.
          </li>
          <li>
            <strong>Sette eemaldamine</strong> – vee ringlus viib kaasa setteid, mis
            võivad radiaatorite sees koguneda ja vähendada nende efektiivsust.
          </li>
          <li>
            <strong>Parandatud soojusülekanne</strong> – õigeaegne hooldus tagab, et
            radiaatorid töötavad maksimaalse efektiivsusega.
          </li>
          <li>
            <strong>Energiakulude vähendamine</strong> – korralikult hooldatud
            küttesüsteem kulutab vähem energiat sama temperatuuri saavutamiseks.
          </li>
          <li>
            <strong>Pikendatud eluiga</strong> – regulaarne hooldus vähendab korrosiooni
            ja pikendab nii radiaatorite kui ka kogu küttesüsteemi eluiga.
          </li>
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          2. Millal tuleks radiaatoreid tühjendada?
        </h2>
        <p class="text-gray-700 mb-3">
          Radiaatorite tühjendamine peaks toimuma kindlatel aegadel:
        </p>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li>
            <strong>Enne küttehooaja algust</strong> – soovitatav on teha hooldus enne,
            kui küttesüsteem käivitatakse. See tagab, et küttehooaja alguses kõik töötab
            korralikult.
          </li>
          <li>
            <strong>Pärast küttehooaja lõppu</strong> – mõned spetsialistid soovitavad
            tühjendada radiaatorid ka pärast küttehooaja lõppu, et eemaldada kogunenud
            seted ja õhk.
          </li>
          <li>
            <strong>Kui märkad probleeme</strong> – kui radiaatorid ei kuumene ühtlaselt,
            teevad müra või üks osa radiaatorist on külmem kui teine, on aeg hooldust
            teha.
          </li>
          <li>
            <strong>Pärast remonti</strong> – kui oled teinud muudatusi küttesüsteemis
            (näiteks paigaldanud uusi radiaatoreid või muutnud torustikku), tuleb
            süsteem õigesti tühjendada ja täita.
          </li>
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          3. Kui tihti tuleks radiaatoreid tühjendada?
        </h2>
        <p class="text-gray-700 mb-3">
          Soovitused sõltuvad küttesüsteemi tüübist ja kasutamisest:
        </p>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li>
            <strong>Kodused küttesüsteemid</strong> – vähemalt kord aastas, eelistatavalt
            enne küttehooaja algust.
          </li>
          <li>
            <strong>Suuremad süsteemid</strong> – korterelamud või suuremad hooned võivad
            vajada sagedasemat hooldust, eriti kui vesi on kõva või süsteemis on palju
            radiaatoreid.
          </li>
          <li>
            <strong>Vanad küttesüsteemid</strong> – kui süsteem on vana või on ajaloo
            jooksul olnud probleeme, võib olla vaja hooldust kaks korda aastas.
          </li>
          <li>
            <strong>Pärast uue süsteemi paigaldamist</strong> – esimesel aastal võib olla
            vaja tühjendada mitu korda, kuni süsteem "istub" ja õhk eemaldatakse.
          </li>
        </ul>
        <p class="text-gray-700 mt-3">
          Üldiselt: kui radiaatorid töötavad korralikult ja ühtlaselt, piisab ühest
          hooldusest aastas. Kui märkad probleeme, ärge oodake – kutsuge professionaalne
          küttesüsteemi toruabi.
        </p>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          4. Kuidas õigesti radiaatoreid tühjendada?
        </h2>
        <p class="text-gray-700 mb-3">
          <strong>Oluline:</strong> Kui teil puudub kogemus, on ohutum kutsuda
          professionaalne torumees. Siiski on kasulik teada põhiprotsessi:
        </p>
        <h3 class="text-xl font-bold text-trust-blue mt-4 mb-2">
          Sammud radiaatorite tühjendamiseks:
        </h3>
        <ol class="list-decimal list-inside text-gray-700 space-y-2 ml-4">
          <li>
            <strong>Lülitage küttesüsteem välja</strong> – oodake, kuni radiaatorid
            jahtuvad. See võtab tavaliselt mitu tundi.
          </li>
          <li>
            <strong>Leidke õhuklapp</strong> – see on väike klapp radiaatori ülaosas,
            tavaliselt vastasküljel võrguühendusest.
          </li>
          <li>
            <strong>Valmistage ette nõu</strong> – asetage nõu või kott õhuklapi alla,
            et kinni püüda vett ja õhku.
          </li>
          <li>
            <strong>Avage õhuklapp</strong> – kasutage spetsiaalset võtit või
            kruvikeeretit. Avage aeglaselt ja laske õhul ja veel välja tulla.
          </li>
          <li>
            <strong>Oodake, kuni vesi lakkab voolamast</strong> – kui vesi lakkab
            voolamast, on õhk eemaldatud. Sulgege õhuklapp.
          </li>
          <li>
            <strong>Kontrollige rõhku</strong> – pärast õhu eemaldamist kontrollige
            küttesüsteemi rõhku ja vajadusel lisage vett.
          </li>
        </ol>
        <p class="text-gray-700 mt-3">
          <strong>Hoiatus:</strong> Ärge kunagi avage õhuklappi, kui radiaator on
          kuum! See võib põhjustada tõsiseid põletusi. Samuti ärge avage õhuklappi
          liiga kiiresti – see võib põhjustada vee väljavoolu.
        </p>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          5. Levinumad vead radiaatorite tühjendamisel
        </h2>
        <p class="text-gray-700 mb-3">
          Paljud inimesed teevad vigu, mis võivad kahjustada küttesüsteemi:
        </p>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li>
            <strong>Õhuklapi avamine kuumal radiaatoril</strong> – see on ohtlik ja
            võib põhjustada põletusi. Oodake alati, kuni radiaator on jahtunud.
          </li>
          <li>
            <strong>Liiga kiire avamine</strong> – kui avate õhuklappi liiga kiiresti,
            võib vesi välja purskuda ja kahjustada põrandat või mööblit.
          </li>
          <li>
            <strong>Õhuklapi mitte sulgemine</strong> – kui unustate õhuklapi sulgeda,
            võib vesi välja voolata ja kahjustada ruume.
          </li>
          <li>
            <strong>Vale õhuklapi kasutamine</strong> – mõned radiaatorid vajavad
            spetsiaalseid tööriistu. Vale tööriista kasutamine võib kahjustada klappi.
          </li>
          <li>
            <strong>Rõhu mitte kontrollimine</strong> – pärast õhu eemaldamist tuleb
            kontrollida süsteemi rõhku. Liiga madal rõhk võib kahjustada boilerit või
            põhjustada ebaühtlast kuumutamist.
          </li>
        </ul>
        <p class="text-gray-700 mt-3">
          Kui teil on kahtlusi või puudub kogemus, on alati parem kutsuda professionaalne
          küttesüsteemi toruabi. Meie meister teab, kuidas õigesti hooldada erinevaid
          küttesüsteeme ja võib vältida kalleid vigu.
        </p>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          6. Millal kindlasti kutsuda küttesüsteemi toruabi?
        </h2>
        <p class="text-gray-700 mb-3">
          Mõned olukorrad nõuavad professionaalse sekkumist:
        </p>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li>
            Kui radiaatorid ei kuumene üldse või kuumenevad väga ebaühtlaselt.
          </li>
          <li>
            Kui kuuled pidevat müra (plärin, vilin, kolin) küttesüsteemist.
          </li>
          <li>
            Kui radiaator lekib või näed niiskust radiaatori ümber.
          </li>
          <li>
            Kui õhuklapp on kinni jäänud või ei tööta.
          </li>
          <li>
            Kui küttesüsteemi rõhk on liiga madal või liiga kõrge.
          </li>
          <li>
            Kui märkad korrosiooni märke radiaatoritel või torustikul.
          </li>
          <li>
            Kui oled ostnud vana maja või korteri ja ei tea küttesüsteemi seisukorda.
          </li>
        </ul>
        <p class="text-gray-700 mt-3">
          Need sümptomid viitavad sellele, et küttesüsteem vajab professionaalset
          hooldust või remonti. Õigeaegne sekkumine hoiab ära suuremad kulud ja võimaliku
          veekahju.
        </p>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          7. Ennetus: kuidas hoida küttesüsteemi korras?
        </h2>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li>
            <strong>Regulaarne hooldus</strong> – laske küttesüsteemil teha hooldust
            vähemalt kord aastas professionaalse torumehe poolt.
          </li>
          <li>
            <strong>Õhuklappide kontroll</strong> – kontrollige perioodiliselt, kas
            õhuklapid töötavad korralikult.
          </li>
          <li>
            <strong>Rõhu jälgimine</strong> – jälgige küttesüsteemi rõhku ja vajadusel
            lisage vett.
          </li>
          <li>
            <strong>Radiaatorite puhastamine</strong> – puhastage radiaatorite välispinda
            regulaarselt, et tagada optimaalne soojusülekanne.
          </li>
          <li>
            <strong>Vana süsteemi asendamine</strong> – kui küttesüsteem on väga vana ja
            pidevalt probleeme tekitab, kaaluge selle osalist või täielikku renoveerimist.
