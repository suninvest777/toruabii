// Categories configuration
const categories = {
  kuttesusteem: {
    name: 'Küttesüsteem',
    nameRu: 'Отопление',
    slug: 'kuttesusteem',
    slugRu: 'otoplenije',
    description: 'Artiklid küttesüsteemi hoolduse, remondi ja radiaatorite kohta',
    descriptionRu: 'Статьи об обслуживании, ремонте систем отопления и радиаторов',
  },
  kanalisatsioon: {
    name: 'Kanalisatsioon',
    nameRu: 'Канализация',
    slug: 'kanalisatsioon',
    slugRu: 'kanalizacija',
    description: 'Artiklid kanalisatsiooni ummistuste ja remondi kohta',
    descriptionRu: 'Статьи о засорах и ремонте канализации',
  },
  boiler: {
    name: 'Boiler',
    nameRu: 'Бойлер',
    slug: 'boiler',
    slugRu: 'boiler',
    description: 'Artiklid boileri hoolduse ja läbipese kohta',
    descriptionRu: 'Статьи об обслуживании и промывке бойлеров',
  },
};

const currentLang = pageLang(Astro.url);

const pageTitleEt = seoBlogIndexTitle('et');
const pageDescEt = seoBlogIndexDescription('et');
const pageTitleRu = seoBlogIndexTitle('ru');
const pageDescRu = seoBlogIndexDescription('ru');

const pageTitle = currentLang === 'ru' ? pageTitleRu : pageTitleEt;
const pageDescription = currentLang === 'ru' ? pageDescRu : pageDescEt;

const blogListPath = '/blog';
const blogCanonical =
  currentLang === 'ru' ? `${siteUrl}${ruPath(blogListPath)}` : `${siteUrl}${blogListPath}`;
const crumbHomeUrl = currentLang === 'ru' ? `${siteUrl}/ru` : `${siteUrl}/`;

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${blogCanonical}#blog`,
  url: blogCanonical,
  name: 'toruabii.ee – Toruabi blogi',
  description:
    'Praktilised artiklid torutööde, kütte ja kanalisatsiooni teemadel Tallinnas ja Harjumaal.',
  inLanguage: currentLang === 'ru' ? 'ru' : 'et',
  publisher: { '@id': `${siteUrl}#organization` },
};

const blogFaqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${blogCanonical}#faq`,
  url: blogCanonical,
  inLanguage: currentLang === 'ru' ? 'ru' : 'et',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Kas blogi artiklid asendavad professionaalset toruabi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ei. Blogi eesmärk on anda lühikesi ja selgeid soovitusi, mida teha enne meistri saabumist ja kuidas vältida tüüpvigu. Päris remondi, ummistuse või lekke korral soovitame alati kutsuda avarii toruabi.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kui tihti lisatakse blogisse uusi artikleid?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Uusi artikleid lisame vastavalt hooajale ja korduvatele küsimustele klientidelt – näiteks enne küttehooaja algust või sagedaste ummistusjuhtumite põhjal.',
      },
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={blogCanonical}
  ogImage="https://toruabii.ee/photos/maintoruabii.webp"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogJsonLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogFaqJsonLd)} />
  <!-- Header -->
  <header class="bg-trust-blue text-white py-6 px-4 pt-4 md:pt-6">
    <div class="max-w-6xl mx-auto">
      <a
        href={homeHref(currentLang)}
        class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold"
      >
        <span data-lang="backToHome">← Tagasi avalehele</span>
      </a>

      <Breadcrumb
        items={[
          { name: currentLang === 'ru' ? 'Главная' : 'Avaleht', url: crumbHomeUrl },
          { name: currentLang === 'ru' ? 'Блог' : 'Blogi', url: blogCanonical },
        ]}
        class="text-gray-300 mb-3"
      />

      <h1 class="text-4xl md:text-5xl font-bold mb-2" data-lang="blogPageTitle">
        Toruabi blogi: praktilised toruabi nõuanded Tallinnas ja Harjumaal
