  <!-- Main Content -->
  <main class="py-12 px-4 bg-gray-50 min-h-screen">
    <!-- Categories Section -->
    <LangOnly lang="et" activeLang={currentLang}>
    <section class="max-w-5xl mx-auto mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-6">Kategooriad</h2>
      <div class="flex flex-wrap gap-4">
        {Object.values(categories).map((cat) => (
          <a
            href={`/blog/kategoria/${cat.slug}`}
            class="inline-block bg-white hover:bg-trust-blue hover:text-white text-trust-blue font-semibold py-3 px-6 rounded-lg shadow-md transition-colors border-2 border-trust-blue"
          >
            {cat.name}
          </a>
        ))}
      </div>
    </section>
    </LangOnly>
    <LangOnly lang="ru" activeLang={currentLang}>
    <section class="max-w-5xl mx-auto mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-6">Категории</h2>
      <div class="flex flex-wrap gap-4">
        {Object.values(categories).map((cat) => (
          <a
            href={ruPath(`/blog/kategoria/${cat.slugRu}`)}
            class="inline-block bg-white hover:bg-trust-blue hover:text-white text-trust-blue font-semibold py-3 px-6 rounded-lg shadow-md transition-colors border-2 border-trust-blue"
          >
            {cat.nameRu}
          </a>
        ))}
      </div>
    </section>
    </LangOnly>

    <!-- Estonian list -->
    <div class="max-w-5xl mx-auto space-y-8">
      {blogPosts.map((post) => (
        <article class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img
            src={post.image}
            alt={post.imageAlt}
            class="w-full h-56 md:h-64 object-cover"
            loading="lazy"
            width="800"
            height="450"
          />
          <div class="p-6 md:p-8">
            <header class="mb-4">
              <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-2">
                <a
                  href={`/blog/${post.slug}`}
                  class="hover:text-emergency-red transition-colors"
                >
                  {post.title}
                </a>
              </h2>
              <p class="text-sm text-gray-500">
                Avaldatud:{' '}
                {new Date(post.date).toLocaleDateString('et-EE', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
            </header>
            <p class="text-gray-700 mb-4">{post.description}</p>
            <a
              href={`/blog/${post.slug}`}
              class="inline-flex items-center text-emergency-red font-semibold hover:underline"
            >
              <span data-lang="blogReadMore">Loe edasi</span>
              <svg
                class="w-4 h-4 ml-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Russian list -->
    <div class="max-w-5xl mx-auto space-y-8">
      {blogPosts.map((post) => (
        <article class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img
            src={post.imageRu}
            alt={post.imageAltRu}
            class="w-full h-56 md:h-64 object-cover"
            loading="lazy"
            width="800"
            height="450"
          />
          <div class="p-6 md:p-8">
            <header class="mb-4">
              <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-2">
                <a
                  href={ruPath(`/blog/${post.slug}`)}
                  class="hover:text-emergency-red transition-colors"
                >
                  {post.titleRu}
                </a>
              </h2>
              <p class="text-sm text-gray-500">
                Опубликовано:{' '}
                {new Date(post.date).toLocaleDateString('ru-RU', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
            </header>
            <p class="text-gray-700 mb-4">{post.descriptionRu}</p>
            <a
              href={ruPath(`/blog/${post.slug}`)}
              class="inline-flex items-center text-emergency-red font-semibold hover:underline"
            >
              <span data-lang="blogReadMore">Читать далее</span>
              <svg
                class="w-4 h-4 ml-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- FAQ block for blog (ET) -->
    <LangOnly lang="et" activeLang={currentLang}>
    <section class="max-w-5xl mx-auto mt-16 space-y-4">
      <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-2">
        KKK blogi kohta
      </h2>
      <details class="bg-white rounded-lg shadow p-4 cursor-pointer">
        <summary class="font-semibold text-trust-blue">
          Kas blogi artiklid asendavad professionaalset toruabi?
        </summary>
        <p class="text-gray-700 mt-3">
          Ei. Blogi eesmärk on anda lühikesi ja selgeid soovitusi, mida teha enne
          meistri saabumist ja kuidas vältida tüüpvigu. Päris remondi, ummistuse
          või lekke korral soovitame alati kutsuda avarii toruabi.
        </p>
      </details>
      <details class="bg-white rounded-lg shadow p-4 cursor-pointer">
        <summary class="font-semibold text-trust-blue">
          Kui tihti lisatakse blogisse uusi artikleid?
        </summary>
        <p class="text-gray-700 mt-3">
          Uusi artikleid lisame vastavalt hooajale ja korduvatele küsimustele
          klientidelt – näiteks enne küttehooaja algust või sagedaste
          ummistusjuhtumite põhjal.
        </p>
      </details>
    </section>
    </LangOnly>
    <!-- FAQ block for blog (RU) -->
    <LangOnly lang="ru" activeLang={currentLang}>
    <section class="max-w-5xl mx-auto mt-16 space-y-4">
      <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-2">
        Часто задаваемые вопросы о блоге
      </h2>
      <details class="bg-white rounded-lg shadow p-4 cursor-pointer">
        <summary class="font-semibold text-trust-blue">
          Заменяют ли статьи в блоге выезд сантехника?
        </summary>
        <p class="text-gray-700 mt-3">
          Нет. Цель блога – дать понятные рекомендации, что делать до приезда
          мастера и каких ошибок избегать. Для реального ремонта, засора или
          протечки лучше сразу вызывать аварийного сантехника.
        </p>
      </details>
      <details class="bg-white rounded-lg shadow p-4 cursor-pointer">
        <summary class="font-semibold text-trust-blue">
          Как часто появляются новые статьи?
        </summary>
        <p class="text-gray-700 mt-3">
          Мы публикуем новые материалы по мере возникновения повторяющихся
          вопросов клиентов и перед важными сезонами, например перед началом
          отопительного периода.
        </p>
      </details>
    </section>
    </LangOnly>
