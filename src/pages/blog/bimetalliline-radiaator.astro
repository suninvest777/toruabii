---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { ruPath } from '../../utils/i18n-paths';
import BlogPostingSchema from '../../components/BlogPostingSchema.astro';
import { sitemapEntries } from '../../data/sitemap-entries';
import { blogArticleBreadcrumbMeta } from '../../data/blog-article-breadcrumbs';
import { blogArticleBreadcrumbOverride } from '../../utils/seo-jsonld';
import { pageLang } from '../../utils/page-lang';
import LangOnly from '../../components/LangOnly.astro';

const phoneNumber = '+372 5181 112';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = pageLang(Astro.url);

const titleEt =
  'Bimetalliline radiaator küttesüsteemis Tallinnas – toruabi, paigaldus ja remont 24/7 | toruabii.ee';
const descEt =
  'Bimetalliline radiaator küttesüsteemis Tallinnas: toruabi 24/7, bimetalliliste radiaatorite paigaldus, remont ja hooldus. Bimetallilised radiaatorid kombineerivad terase tugevuse ja alumiiniumi soojusülekande. Professionaalne bimetalliliste radiaatorite torumees Lasnamäes, Mustamäel, Kesklinnas, Piritas, Viimsis. Bimetalliliste radiaatorite eelised, võimsus, sektsioonid.';
const titleRu =
  'Биметаллический радиатор отопления – что это такое и в чем преимущества? | toruabii.ee';
const descRu =
  'Биметаллические радиаторы отопления сочетают прочность стали и теплоотдачу алюминия. Рассказываем, что собой представляют биметаллические радиаторы, технические отличия и особенности эксплуатации в Таллине и Харьюмаа.';

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const articlePath = '/blog/bimetalliline-radiaator';
const articleDatePublished = sitemapEntries.find((e) => e.path === articlePath)?.lastmod ?? '2026-01-01';
const siteOrigin = 'https://toruabii.ee';
const canonicalUrl = currentLang === 'ru' ? `${siteOrigin}${ruPath(articlePath)}` : `${siteOrigin}${articlePath}`;
const articleCrumb = blogArticleBreadcrumbMeta['bimetalliline-radiaator'];
const breadcrumbJsonLdOverride = blogArticleBreadcrumbOverride(
  articlePath,
  currentLang,
  articleCrumb.category,
  articleCrumb.crumbNameEt,
  articleCrumb.crumbNameRu
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={canonicalUrl}
  ogImage="https://toruabii.ee/photos/otoplenije-batarei-liking.webp"
  ogType="article"
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <BlogPostingSchema
    slot="head"
    lang={currentLang}
    headlineEt={titleEt}
    headlineRu={titleRu}
    descriptionEt={descEt}
    descriptionRu={descRu}
    canonicalPath={articlePath}
    datePublished={articleDatePublished}
    imageUrl="https://toruabii.ee/photos/otoplenije-batarei-liking.webp"
  />
  <script
    slot="head"
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': canonicalUrl + '#faq',
    url: canonicalUrl,
    inLanguage: currentLang,
    mainEntity: [
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Что такое биметаллический радиатор и почему он популярен в Таллине?' : 'Mis on bimetalliline radiaator ja miks see on populaarne Tallinnas?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Биметаллический радиатор сочетает прочность стали и теплоотдачу алюминия. Это популярный выбор в Таллине, так как подходит как для новых, так и для старых систем отопления и выдерживает высокое давление.'
            : 'Bimetalliline radiaator kombineerib terase tugevuse ja alumiiniumi soojusülekande. See on populaarne valik Tallinnas, kuna sobib nii uutele kui vanadele küttesüsteemidele ja talub kõrget rõhku.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Сколько стоит установка биметаллических радиаторов в Таллине?' : 'Kui palju maksab bimetalliliste radiaatorite paigaldus Tallinnas?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Стоимость установки биметаллических радиаторов в Таллине зависит от количества радиаторов и сложности установки. Установка одного биметаллического радиатора может стоить 200-400€, установка всех радиаторов в доме 1500-4000€.'
            : 'Bimetalliliste radiaatorite paigalduse hind Tallinnas sõltub radiaatorite arvust ja paigalduse keerukusest. Ühe bimetallilise radiaatori paigaldus võib maksta 200-400€, kogu maja radiaatorite paigaldus 1500-4000€.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Подходят ли биметаллические радиаторы для старых систем отопления?' : 'Kas bimetallilised radiaatorid sobivad vanadele küttesüsteemidele?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Да, биметаллические радиаторы хорошо подходят как для новых, так и для старых систем отопления в Таллине. Стальные трубы обеспечивают долговечность для старых систем с высоким давлением.'
            : 'Jah, bimetallilised radiaatorid sobivad hästi nii uutele kui vanadele küttesüsteemidele Tallinnas. Terasest torud tagavad vastupidavuse vanade süsteemide kõrge rõhu jaoks.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Как долго длится установка биметаллических радиаторов?' : 'Kui kaua kestab bimetalliliste radiaatorite paigaldus?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Установка биметаллических радиаторов обычно занимает 1-3 дня, в зависимости от количества радиаторов и сложности системы. Установка одного радиатора может занять 2-4 часа.'
            : 'Bimetalliliste radiaatorite paigaldus võtab tavaliselt 1-3 päeva, olenevalt radiaatorite arvust ja süsteemi keerukusest. Ühe radiaatori paigaldus võib võtta 2-4 tundi.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Какой срок службы биметаллических радиаторов?' : 'Milline on bimetalliliste radiaatorite eluiga?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Срок службы биметаллических радиаторов обычно составляет 20-30 лет, если они правильно установлены и обслуживаются. Регулярное обслуживание и правильное использование значительно продлевает срок службы радиаторов.'
            : 'Bimetalliliste radiaatorite eluiga on tavaliselt 20-30 aastat, kui need on õigesti paigaldatud ja hooldatud. Regulaarne hooldus ja õige kasutamine pikendab radiaatorite eluiga oluliselt.',
        },
      },
    ],
  })}
/>

<!-- Estonian header -->
