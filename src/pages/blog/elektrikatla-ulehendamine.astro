---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { ruPath } from '../../utils/i18n-paths';
import BlogPostingSchema from '../../components/BlogPostingSchema.astro';
import { sitemapEntries } from '../../data/sitemap-entries';
import { blogArticleBreadcrumbMeta } from '../../data/blog-article-breadcrumbs';
import { blogArticleBreadcrumbOverride } from '../../utils/seo-jsonld';
import { pageLang } from '../../utils/page-lang';
import LangOnly from '../../components/LangOnly.astro';

const phoneNumber = '+372 5181 112';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = pageLang(Astro.url);

const titleEt =
  'Elektrikatla ühendamine küttesüsteemiga Tallinnas – toruabi, paigaldus ja remont 24/7 | toruabii.ee';
const descEt =
  'Elektrikatla ühendamine küttesüsteemiga Tallinnas: toruabi 24/7, elektrikatla paigaldus, ühendamine ja remont. Elektrikatla skeemid, ühendamine, paigaldus. Professionaalne elektrikatla torumees Lasnamäes, Mustamäel, Kesklinnas, Piritas, Viimsis. Elektrikatla valik, võimsus, ohutusnõuded.';
const titleRu =
  'Подключение электрокотла к системе отопления в Таллине – руководство и схемы | toruabii.ee';
const descRu =
  'Подключение электрокотла в систему отопления требует тщательного планирования и профессиональной установки. Рассказываем о строении, подготовке и выборе схемы подключения электрического котла в Таллине и Харьюмаа.';

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const articlePath = '/blog/elektrikatla-ulehendamine';
const articleDatePublished = sitemapEntries.find((e) => e.path === articlePath)?.lastmod ?? '2026-01-01';
const siteOrigin = 'https://toruabii.ee';
const canonicalUrl = currentLang === 'ru' ? `${siteOrigin}${ruPath(articlePath)}` : `${siteOrigin}${articlePath}`;
const articleCrumb = blogArticleBreadcrumbMeta['elektrikatla-ulehendamine'];
const breadcrumbJsonLdOverride = blogArticleBreadcrumbOverride(
  articlePath,
  currentLang,
  articleCrumb.category,
  articleCrumb.crumbNameEt,
  articleCrumb.crumbNameRu
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={canonicalUrl}
  ogImage="https://toruabii.ee/photos/sistema-otoplenija-connectors-liking.webp"
  ogType="article"
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <BlogPostingSchema
    slot="head"
    lang={currentLang}
    headlineEt={titleEt}
    headlineRu={titleRu}
    descriptionEt={descEt}
    descriptionRu={descRu}
    canonicalPath={articlePath}
    datePublished={articleDatePublished}
    imageUrl="https://toruabii.ee/photos/sistema-otoplenija-connectors-liking.webp"
  />
  <script
    slot="head"
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': canonicalUrl + '#faq',
    url: canonicalUrl,
    inLanguage: currentLang,
    mainEntity: [
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Сколько стоит подключение электрокотла в Таллине?' : 'Kui palju maksab elektrikatla ühendamine Tallinnas?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Стоимость подключения электрокотла в Таллине зависит от мощности котла и сложности системы. Простое подключение может стоить 500-1000€, более сложная система 1500-3000€.'
            : 'Elektrikatla ühendamise hind Tallinnas sõltub katla võimsusest ja süsteemi keerukusest. Lihtsam ühendamine võib maksta 500-1000€, keerukam süsteem 1500-3000€.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Можно ли подключить электрокотел самостоятельно?' : 'Kas elektrikatla saab ühendada ise?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Подключение электрокотла требует профессиональных знаний как в области сантехники, так и в области электрики. Неправильное подключение может привести к пожару, поражению электрическим током или повреждению системы.'
            : 'Elektrikatla ühendamine nõuab professionaalseid teadmisi nii torustiku kui ka elektri jaoks. Vale ühendamine võib põhjustada tuleohtu, elektrilööki või süsteemi kahjustusi.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Каковы основные требования для подключения электрокотла?' : 'Millised on elektrikatla ühendamise peamised nõuded?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Основные требования для подключения электрокотла: правильное электрическое подключение квалифицированным электриком, правильное заземление, рабочий предохранительный клапан, правильное давление системы и удаление воздуха из системы.'
            : 'Elektrikatla ühendamise peamised nõuded on õige elektriline ühendus kvalifitseeritud elektriku poolt, õige maandus, töökorras ohutusklapp, õige süsteemi rõhk ja õhu eemaldamine süsteemist.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Как долго длится подключение электрокотла?' : 'Kui kaua võtab elektrikatla ühendamine aega?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Подключение электрокотла обычно занимает 1-2 дня, в зависимости от сложности системы и необходимости внесения изменений в трубопровод или электрическую систему. Простое подключение может занять 4-8 часов.'
            : 'Elektrikatla ühendamine võtab tavaliselt 1-2 päeva, olenevalt süsteemi keerukusest ja vajadusest teha muudatusi torustikus või elektrisüsteemis. Lihtsam ühendamine võib võtta 4-8 tundi.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Какой электрокотел лучше выбрать в Таллине?' : 'Milline elektrikatel on parim valik Tallinnas?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Выбор электрокотла зависит от размера дома, потребности в тепле и бюджета. Наш мастер поможет выбрать правильный котел для вашего дома, учитывая все факторы.'
            : 'Elektrikatla valik sõltub maja suurusest, soojusvajadusest ja eelarvest. Meie torumees aitab valida õige katla teie maja jaoks, arvestades kõiki tegureid.',
        },
      },
    ],
  })}
/>

<!-- Estonian header -->
  <LangOnly lang="et" activeLang={currentLang}>
<header class="bg-trust-blue text-white py-6 px-4">
    <div class="max-w-5xl mx-auto">
      <nav class="text-sm text-gray-300 mb-3" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1">
          <li><a href="/" class="hover:text-white">Avaleht</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/blog" class="hover:text-white">Blogi</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/blog/kategoria/kuttesusteem" class="hover:text-white">Küttesüsteem</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-200">Elektrikatla ühendamine</li>
        </ol>
      </nav>
      <a href="/blog/kategoria/kuttesusteem" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">
        ← Tagasi küttesüsteemi artiklite juurde
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">
        Elektrikatla ühendamine küttesüsteemiga Tallinnas: toruabi, paigaldus ja remont 24/7
      </h1>
      <p class="text-gray-200 max-w-2xl">
        Vajate elektrikatla ühendamist, paigaldust või remonti Tallinnas? Meie professionaalne torumees pakub elektrikatla toruabi 24/7 Lasnamäes, Mustamäel, Kesklinnas, Piritas, Viimsis ja kõigis Tallinna piirkondades. Elektrikatla ühendamine küttesüsteemiga nõuab hoolikat planeerimist ja professionaalset paigaldust. Selgitame elektrikatla ehitust, ettevalmistust ja ühendamise skeeme Tallinnas ja Harjumaal.
      </p>
      <p class="text-sm text-gray-300 mt-3">
        Avaldatud: {new Date('2023-01-31').toLocaleDateString('et-EE', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </div>
  </header>
</LangOnly>

  <!-- Russian header -->
  <LangOnly lang="ru" activeLang={currentLang}>
<header class="bg-trust-blue text-white py-6 px-4">
    <div class="max-w-5xl mx-auto">
      <nav class="text-sm text-gray-300 mb-3" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1">
          <li><a href="/ru" class="hover:text-white">Главная</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/ru/blog" class="hover:text-white">Блог</a></li>
          <li aria-hidden="true">›</li>
          <li><a href="/ru/blog/kategoria/otoplenije" class="hover:text-white">Отопление</a></li>
          <li aria-hidden="true">›</li>
          <li class="text-gray-200">Подключение электрокотла</li>
        </ol>
      </nav>
      <a href="/ru/blog/kategoria/otoplenije" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">
        ← Назад к статьям об отоплении
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-3">
        Подключение электрокотла к системе отопления: руководство и схемы
      </h1>
      <p class="text-gray-200 max-w-2xl">
        Подключение электрокотла в систему отопления требует тщательного планирования и профессиональной установки. Рассказываем о строении, подготовке и выборе схемы подключения электрического котла в Таллине и Харьюмаа.
      </p>
      <p class="text-sm text-gray-300 mt-3">
        Опубликовано: {new Date('2023-01-31').toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </div>
  </header>
</LangOnly>

  <main class="py-12 px-4 bg-gray-50 min-h-screen">
    <LangOnly lang="et" activeLang={currentLang}>
<article class="max-w-5xl mx-auto bg-white rounded-lg shadow-lg p-6 md:p-8">
      <figure class="mb-6">
        <img
          src="/photos/sistema-otoplenija-connectors-liking.webp"
          alt="Elektrikatla ühendamine küttesüsteemiga Tallinnas – professionaalne paigaldus"
          class="w-full h-64 md:h-80 object-cover rounded-lg"
          loading="eager"
          width="1000"
          height="600"
        />
      </figure>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          1. Elektrikatla ehituse põhiosad
        </h2>
        <p class="text-gray-700 mb-3">
          Elektrikatla koosneb mitmest olulisest komponendist:
        </p>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li><strong>Küttekehad</strong> – elektroodid või küttekehad, mis kuumutavad vett</li>
          <li><strong>Juhtpaneel</strong> – temperatuuri ja töörežiimide reguleerimiseks</li>
          <li><strong>Ohutussüsteemid</strong> – ülekuumenemise ja rõhu kaitse</li>
          <li><strong>Tsirkulatsioonipump</strong> – vee liikumise tagamiseks süsteemis</li>
          <li><strong>Laienduspaak</strong> – rõhu kompenseerimiseks</li>
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          2. Ettevalmistus enne paigaldust
        </h2>
        <p class="text-gray-700 mb-3">
          Enne elektrikatla paigaldust on oluline:
        </p>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li><strong>Kontrollida elektrivarustust</strong> – kas on piisav võimsus ja õige pinge</li>
          <li><strong>Valmistada paigalduskoht</strong> – tasane pind, ligipääs hoolduseks</li>
          <li><strong>Kontrollida küttesüsteemi</strong> – kas süsteem on valmis ühendamiseks</li>
          <li><strong>Valmistada vajalikud komponendid</strong> – torud, liitmikud, klapid</li>
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          3. Ühendamise skeemid
        </h2>
        <h3 class="text-xl font-bold text-trust-blue mt-4 mb-2">Lihtne skeem</h3>
        <p class="text-gray-700 mb-3">
          Lihtsaim skeem on otseühendus küttesüsteemiga. Katel on ühendatud radiaatoritega või põrandaküttega. See skeem sobib väiksematele süsteemidele.
        </p>
        <h3 class="text-xl font-bold text-trust-blue mt-4 mb-2">Kombineeritud skeem</h3>
        <p class="text-gray-700 mb-3">
          Kombineeritud skeem võimaldab ühendada nii radiaatorid kui ka põrandakütte. See nõuab kollektorsüsteemi ja eraldi reguleerimist.
        </p>
        <h3 class="text-xl font-bold text-trust-blue mt-4 mb-2">Kaskaadne skeem</h3>
        <p class="text-gray-700 mb-3">
          Kaskaadne skeem kasutab mitut katlat paralleelselt. See sobib suurematele süsteemidele ja tagab parema efektiivsuse.
        </p>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-4">
          4. Olulised ohutusnõuded
        </h2>
        <ul class="list-disc list-inside text-gray-700 space-y-2">
          <li><strong>Õige elektriline ühendus</strong> – peab olema tehtud kvalifitseeritud elektrik poolt</li>
          <li><strong>Maandus</strong> – katel peab olema õigesti maandatud</li>
          <li><strong>Ohutusklapp</strong> – peab olema paigaldatud ja töökorras</li>
          <li><strong>Rõhu kontroll</strong> – süsteemi rõhk peab olema õige</li>
          <li><strong>Õhu eemaldamine</strong> – süsteemist peab olema eemaldatud õhk</li>
        </ul>
      </section>

      <!-- Category Section -->
      <section class="bg-white rounded-lg shadow-lg p-6 mb-8">
        <LangOnly lang="et" activeLang={currentLang}>
        <h2 class="text-2xl font-bold text-trust-blue mb-4">Rohkem artikleid küttesüsteemi kohta</h2>
        <div class="flex justify-center">
          <a href="/blog/kategoria/kuttesusteem" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors">
            Küttesüsteemi artiklid
          </a>
        </div>
      </LangOnly>
      <LangOnly lang="ru" activeLang={currentLang}>
        <h2 class="text-2xl font-bold text-trust-blue mb-4">Больше статей об отоплении</h2>
        <div class="flex justify-center">
          <a href="/ru/blog/kategoria/otoplenije" class="inline-block bg-trust-blue hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg transition-colors">
            Статьи об отоплении
          </a>
        </div>
      </LangOnly>
      </section>

      <!-- FAQ Section -->
      <section class="bg-white rounded-lg shadow-lg p-6 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-trust-blue mb-6">Korduma kippuvad küsimused elektrikatla ühendamise kohta Tallinnas</h2>
        <div class="space-y-4">
          <details class="bg-gray-50 rounded-lg p-4 cursor-pointer">
            <summary class="font-semibold text-trust-blue text-lg cursor-pointer">
              Kui palju maksab elektrikatla ühendamine Tallinnas?
            </summary>
            <p class="text-gray-700 mt-3">
              Elektrikatla ühendamise hind Tallinnas sõltub katla võimsusest ja süsteemi keerukusest. Lihtsam ühendamine võib maksta 500-1000€, keerukam süsteem 1500-3000€. Meie torumees annab tasuta hinnapakkumise pärast esialgset ülevaadet. Pakume elektrikatla toruabi Lasnamäes, Mustamäel, Kesklinnas, Piritas ja Viimsis 24/7.
            </p>
          </details>
          <details class="bg-gray-50 rounded-lg p-4 cursor-pointer">
            <summary class="font-semibold text-trust-blue text-lg cursor-pointer">
              Kas elektrikatla saab ühendada ise?
            </summary>
            <p class="text-gray-700 mt-3">
              Elektrikatla ühendamine nõuab professionaalseid teadmisi nii torustiku kui ka elektri jaoks. Vale ühendamine võib põhjustada tuleohtu, elektrilööki või süsteemi kahjustusi. Soovitame alati kasutada professionaalse torumehe ja elektriku teenuseid. Meie töömeeskond koosneb nii torumeestest kui ka elektrikutest.
            </p>
          </details>
          <details class="bg-gray-50 rounded-lg p-4 cursor-pointer">
            <summary class="font-semibold text-trust-blue text-lg cursor-pointer">
              Millised on elektrikatla ühendamise peamised nõuded?
            </summary>
            <p class="text-gray-700 mt-3">
              Elektrikatla ühendamise peamised nõuded on õige elektriline ühendus kvalifitseeritud elektriku poolt, õige maandus, töökorras ohutusklapp, õige süsteemi rõhk ja õhu eemaldamine süsteemist. Kõik need nõuded peavad olema täidetud ohutuse tagamiseks.
            </p>
          </details>
          <details class="bg-gray-50 rounded-lg p-4 cursor-pointer">
            <summary class="font-semibold text-trust-blue text-lg cursor-pointer">
              Kui kaua võtab elektrikatla ühendamine aega?
            </summary>
            <p class="text-gray-700 mt-3">
              Elektrikatla ühendamine võtab tavaliselt 1-2 päeva, olenevalt süsteemi keerukusest ja vajadusest teha muudatusi torustikus või elektrisüsteemis. Lihtsam ühendamine võib võtta 4-8 tundi. Meie professionaalne meeskond töötab kiiresti ja efektiivselt.
            </p>
          </details>
          <details class="bg-gray-50 rounded-lg p-4 cursor-pointer">
            <summary class="font-semibold text-trust-blue text-lg cursor-pointer">
              Milline elektrikatla on parim valik Tallinnas?
            </summary>
            <p class="text-gray-700 mt-3">
              Elektrikatla valik sõltub maja suurusest, soojusvajadusest ja eelarvest. Meie torumees aitab valida õige katla teie maja jaoks, arvestades kõiki tegureid. Soovitame alati valida kvaliteetset katla ja professionaalset paigaldust.
            </p>
          </details>
        </div>
      </section>

      <!-- Related Articles Section -->
      <section class="bg-gray-50 rounded-lg p-6 mb-8">
        <h2 class="text-2xl font-bold text-trust-blue mb-4">Seotud artiklid küttesüsteemi kohta</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <a href="/blog/kuttesusteem-eramaja" class="block bg-white p-4 rounded-lg shadow hover:shadow-lg transition-shadow">
            <h3 class="font-bold text-trust-blue mb-2">Küttesüsteem eramajas</h3>
