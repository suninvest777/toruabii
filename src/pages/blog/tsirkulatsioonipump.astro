---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { ruPath } from '../../utils/i18n-paths';
import BlogPostingSchema from '../../components/BlogPostingSchema.astro';
import { sitemapEntries } from '../../data/sitemap-entries';
import { blogArticleBreadcrumbMeta } from '../../data/blog-article-breadcrumbs';
import { blogArticleBreadcrumbOverride } from '../../utils/seo-jsonld';
import { pageLang } from '../../utils/page-lang';
import LangOnly from '../../components/LangOnly.astro';

const phoneNumber = '+372 5633 3332';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = pageLang(Astro.url);

const titleEt =
  'Tsirkulatsioonipump küttesüsteemis Tallinnas – toruabi, paigaldus ja remont 24/7 | toruabii.ee';
const descEt =
  'Tsirkulatsioonipump küttesüsteemis Tallinnas: toruabi 24/7, tsirkulatsioonipumba paigaldus, remont ja hooldus. Pump margi ja kuiva rootoriga. Professionaalne tsirkulatsioonipumba torumees Lasnamäes, Mustamäel, Kesklinnas, Piritas, Viimsis. Tsirkulatsioonipumba valik, võimsus, rõhk.';
const titleRu =
  'Циркуляционный насос в системе отопления – устройство и назначение | toruabii.ee';
const descRu =
  'Циркуляционный насос - это устройство, используемое в системах отопления и горячего водоснабжения для обеспечения принудительной циркуляции теплоносителя. Рассказываем, как работает циркуляционный насос и каково его назначение в Таллине и Харьюмаа.';

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const articlePath = '/blog/tsirkulatsioonipump';
const articleDatePublished = sitemapEntries.find((e) => e.path === articlePath)?.lastmod ?? '2026-01-01';
const siteOrigin = 'https://toruabii.ee';
const canonicalUrl = currentLang === 'ru' ? `${siteOrigin}${ruPath(articlePath)}` : `${siteOrigin}${articlePath}`;
const articleCrumb = blogArticleBreadcrumbMeta['tsirkulatsioonipump'];
const breadcrumbJsonLdOverride = blogArticleBreadcrumbOverride(
  articlePath,
  currentLang,
  articleCrumb.category,
  articleCrumb.crumbNameEt,
  articleCrumb.crumbNameRu
);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={canonicalUrl}
  ogImage="https://toruabii.ee/photos/sistema-otoplenija-connectors-liking.webp"
  ogType="article"
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <BlogPostingSchema
    slot="head"
    lang={currentLang}
    headlineEt={titleEt}
    headlineRu={titleRu}
    descriptionEt={descEt}
    descriptionRu={descRu}
    canonicalPath={articlePath}
    datePublished={articleDatePublished}
    imageUrl="https://toruabii.ee/photos/sistema-otoplenija-connectors-liking.webp"
  />
  <script
    slot="head"
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': canonicalUrl + '#faq',
    url: canonicalUrl,
    inLanguage: currentLang,
    mainEntity: [
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Что такое циркуляционный насос и зачем он нужен?' : 'Mis on tsirkulatsioonipump ja miks see on vajalik?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Циркуляционный насос обеспечивает постоянное движение воды в системе отопления, позволяя равномерно распределять тепло во всех помещениях. Без циркуляционного насоса система отопления может работать неэффективно.'
            : 'Tsirkulatsioonipump tagab pideva vee liikumise küttesüsteemis, võimaldades ühtlast soojusjaotust kõigis ruumides. Ilma tsirkulatsioonipumbata võib küttesüsteem töötada ebaefektiivselt.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Сколько стоит установка циркуляционного насоса в Таллине?' : 'Kui palju maksab tsirkulatsioonipumba paigaldus Tallinnas?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Стоимость установки циркуляционного насоса в Таллине зависит от типа насоса и сложности системы. Установка насоса с мокрым ротором может стоить 300-600€, установка насоса с сухим ротором 500-1000€.'
            : 'Tsirkulatsioonipumba paigalduse hind Tallinnas sõltub pumba tüübist ja süsteemi keerukusest. Märja rootoriga pumba paigaldus võib maksta 300-600€, kuiva rootoriga pumba paigaldus 500-1000€.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Когда нужен циркуляционный насос?' : 'Millal on vaja tsirkulatsioonipumpa?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Циркуляционный насос необходим для всех закрытых систем отопления, особенно для больших частных домов и систем теплого пола. Он обеспечивает равномерное распределение тепла и лучшую энергоэффективность.'
            : 'Tsirkulatsioonipump on vajalik kõigile suletud küttesüsteemidele, eriti suurematele eramajadele ja põrandakütte süsteemidele. See tagab ühtlase soojusjaotuse ja parema energiatõhususe.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Как выбрать правильный циркуляционный насос?' : 'Kuidas valida õige tsirkulatsioonipump?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Выбор циркуляционного насоса зависит от объема системы, длины трубопровода, количества радиаторов и наличия теплого пола. Наш мастер поможет выбрать правильный насос для вашей системы.'
            : 'Tsirkulatsioonipumba valik sõltub süsteemi mahust, torustiku pikkusest, radiaatorite arvust ja põrandakütte olemasolust. Meie torumees aitab valida õige pumba teie süsteemi jaoks.',
        },
      },
      {
        '@type': 'Question',
        name: currentLang === 'ru' ? 'Как часто нужно обслуживать циркуляционный насос?' : 'Kui tihti peaks tsirkulatsioonipumpa hooldama?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: currentLang === 'ru'
            ? 'Рекомендуем проводить обслуживание циркуляционного насоса раз в год, желательно перед началом отопительного сезона. Это включает проверку, очистку и при необходимости ремонт.'
            : 'Tsirkulatsioonipumba hooldust soovitame teha kord aastas, eelistatavalt enne küttehooaja algust. See hõlmab kontrollimist, puhastamist ja vajadusel remonti.',
        },
      },
    ],
  })}
/>

<!-- Estonian header -->
  <LangOnly lang="et" activeLang={currentLang}>
<header class="bg-trust-blue text-white py-6 px-4">
    <div class="max-w-5xl mx-auto">
      <nav class="text-sm text-gray-300 mb-3" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1">
          <li><a href="/" class="hover:text-white">Avaleht</a></li>
