---
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import DistrictCrossLinks from '../components/DistrictCrossLinks.astro';
import FooterLegal from '../components/FooterLegal.astro';
import CallStripCta from '../components/CallStripCta.astro';
import DistrictTallinnJsonLd from '../components/seo/DistrictTallinnJsonLd.astro';
import { tallinnDistrictBreadcrumbJsonLd, tallinnDistrictPageUrl } from '../utils/district-tallinn-jsonld';
import { pageLang } from '../utils/page-lang';
import {
  getTallinnDistrict,
  tallinnDistrictDescription,
  tallinnDistrictH1,
  tallinnDistrictIntro,
  tallinnDistrictTitle,
} from '../data/seo-keywords';

const siteUrl = 'https://toruabii.ee';
const districtSeo = getTallinnDistrict('mustamae');

const phoneNumber = '+372 5181 112';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = pageLang(Astro.url);

const titleEt = tallinnDistrictTitle('mustamae', 'et');
const descEt = tallinnDistrictDescription('mustamae', 'et');
const titleRu = tallinnDistrictTitle('mustamae', 'ru');
const descRu = tallinnDistrictDescription('mustamae', 'ru');

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const districtPath = '/toruabi-mustamae';
const pageCanonicalUrl = tallinnDistrictPageUrl(districtPath, currentLang);
const breadcrumbJsonLdOverride = tallinnDistrictBreadcrumbJsonLd(districtPath, currentLang, titleEt, titleRu);

const mustamaeFaqEt = [
  {
    q: 'Kui kiiresti saab toruabi Mustamäesse?',
    a: 'Mustamäe piirkonnas jõuame tavaliselt 30-50 minutiga kohale. Avariikõnedele reageerime kohe.',
  },
  {
    q: 'Millised on toruabi hinnad Mustamäel?',
    a: 'Toruabi hinnad Mustamäel on samad, mis kogu Tallinnas. Väljasõit on 0€. Vaata täielikku hinnakirja meie veebilehelt.',
  },
  {
    q: 'Kas toruabi töötab Mustamäel ööpäevaringselt?',
    a: 'Jah, oleme kättesaadavad 24/7 avariikõnedele Mustamäel. Planeeritud tööde jaoks töötame tavapäraselt kella 8-20 vahel.',
  },
  {
    q: 'Kas teil on kogemus Mustamäe uusarendustega?',
    a: 'Jah, meil on pikk kogemus töötamisega Mustamäe uusarendustes. Tunneme nende hoonete spetsiifikaid ja teame, kuidas kiiresti lahendada probleeme uutes torustikes.',
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={pageCanonicalUrl}
  ogImage="https://toruabii.ee/photos/maintoruabii.webp"
  suppressPlumbingJsonLd
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <DistrictTallinnJsonLd
    slot="head"
    districtPath={districtPath}
    currentLang={currentLang}
    pageDescription={pageDescription}
    addressLocality="Mustamäe"
    areaServedName="Mustamäe"
    plumbingDisplayNameEt="toruabii.ee - Toruabi Mustamäel"
    plumbingDisplayNameRu="toruabii.ee — торуаби в Мустамяэ"
    offerCatalogNameEt="Toruabi teenused Mustamäel"
    offers={[
      {
        nameEt: 'Toruabi Mustamäel',
        descEt: 'Avarii toruabi ja sanitaartehnilised tööd Mustamäe piirkonnas 24/7',
      },
      {
        nameEt: 'Kanalisatsiooni toruabi Mustamäel',
        descEt: 'Ummistuste likvideerimine ja kanalisatsiooni hooldus Mustamäel',
      },
      {
        nameEt: 'Boileri toruabi Mustamäel',
        descEt: 'Boileri hooldus ja remont Mustamäe piirkonnas',
      },
    ]}
    faqEt={mustamaeFaqEt}
  />
  <!-- Desktop Navigation -->
  
  <!-- Hero Section -->
  <header class="bg-trust-blue text-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <Breadcrumb
        items={[
          { name: currentLang === 'ru' ? 'Главная' : 'Avaleht', url: currentLang === 'ru' ? siteUrl + '/ru' : siteUrl + '/' },
          { name: currentLang === 'ru' ? 'Торуаби по районам' : 'Toruabi piirkondades', url: siteUrl + '/#piirkonnad' },
          { name: currentLang === 'ru' ? 'Торуаби в Мустамяэ' : 'Toruabi Mustamäel', url: siteUrl + '/toruabi-mustamae' }
        ]}
        class="text-gray-300 mb-3"
      />
      {currentLang === 'ru' ? (
        <a href="/ru" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">← На главную</a>
      ) : (
        <a href="/" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">← Tagasi avalehele</a>
      )}
      <h1 class="text-4xl md:text-5xl font-bold mb-3">{currentLang === 'ru' ? tallinnDistrictH1('mustamae', 'ru') : tallinnDistrictH1('mustamae', 'et')}</h1>
      <p class="text-xl text-gray-200 mb-6">{currentLang === 'ru' ? tallinnDistrictIntro('mustamae', 'ru') : tallinnDistrictIntro('mustamae', 'et')}</p>
      <a href={`tel:${phoneLink}`} class="inline-block bg-emergency-red hover:bg-red-700 text-white font-bold py-4 px-8 rounded-lg text-xl">
        <span data-lang="callNowFull">HELISTA KOHE</span>: {phoneNumber}
      </a>
    </div>
  </header>

  <main class="py-12 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto space-y-12">

      <CallStripCta variant="page" />
      
      <!-- Why Choose Toruabi Mustamäel -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Miks valida toruabi Mustamäel?</h2>
        <h3 class="text-lg font-semibold text-trust-blue mb-3">Peamised põhjused</h3>
        <p class="text-gray-700 mb-4">Mustamäe on lääne-Tallinna mikrorajoonide võrgustik, kus uued korterelamud ja 1980. aastate majad kasutavad erinevat torustikku. Brigaad lahendab Mustamäel nii küttekollektorite rikeid kui köögi- ja vannitoa ummistusi, arvestades objekti vanust ja ligipääsu parklatesse.</p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Kogemus uusarendustega:</strong> Meil on pikk kogemus töötamisega Mustamäe uusarendustes ja teame nende spetsiifikaid</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Kiire reageerimine:</strong> Mustamäe piirkonnas jõuame kohale tavaliselt 30-50 minutiga</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Boileri toruabi:</strong> Pakume professionaalset boileri hooldust ja läbipesu Mustamäel</li>
        </ul>
        
        <div class="bg-trust-blue text-white rounded-lg p-6 mt-6">
          <h3 class="text-2xl font-bold mb-4">Toruabi Mustamäel – meie statistikat</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-bold mb-2">432+</div>
              <p class="text-gray-200">Rahulolu klienti Mustamäel</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">40 min</div>
              <p class="text-gray-200">Keskmine reageerimisaeg</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">10+</div>
              <p class="text-gray-200">Aastat kogemust Mustamäel</p>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Почему выбирают торуаби в Мустамяэ?</h2>
        <h3 class="text-lg font-semibold text-trust-blue mb-3">Основные причины</h3>
        <p class="text-gray-700 mb-4">Мустамяэ – второй по величине район Таллина с более чем 70 000 жителей. Наша команда хорошо знает район и предлагает быструю помощь как в новостройках, так и в старых домах.</p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Опыт с новостройками:</strong> У нас большой опыт работы в новостройках Мустамяэ и мы знаем их специфику</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Быстрое реагирование:</strong> В районе Мустамяэ мы обычно приезжаем за 30-50 минут</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Обслуживание бойлеров:</strong> Предлагаем профессиональное обслуживание и промывку бойлеров в Мустамяэ</li>
        </ul>
        
        <div class="bg-trust-blue text-white rounded-lg p-6 mt-6">
          <h3 class="text-2xl font-bold mb-4">Торуаби в Мустамяэ – наша статистика</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-bold mb-2">432+</div>
              <p class="text-gray-200">Довольных клиентов в Мустамяэ</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">40 мин</div>
              <p class="text-gray-200">Среднее время реагирования</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">10+</div>
              <p class="text-gray-200">Лет опыта в Мустамяэ</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Services in Mustamäe -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi teenused Mustamäel</h2>
        <p class="text-gray-700 mb-6">Mustamäe piirkonnas pakume kõiki toruabi teenuseid, sealhulgas:</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Toruabi Mustamäe uusarendustes</h3>
            <p class="text-gray-700 mb-3">Hiiu ja Väike-Õismäe uued korterelamud kasutavad plast- ja roostevabast torustikku — paigaldame ja parandame segisteid, WC-süsteeme ja pesumasinavoolikuid ilma fassaadi kahjustamata.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Sanitaarseadmete paigaldus ja remont</li>
              <li>Kanalisatsiooni toruabi uusarendustes</li>
              <li>Boileri toruabi ja hooldus</li>
              <li>Küttesüsteemi toruabi</li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Boileri toruabi ja hooldus Mustamäel</h3>
            <p class="text-gray-700 mb-3">Kadaka ja Sääse mikrorajoonides on palju 80. aastate maju, kus boiler vajab hooajalist läbipesu ja anoodi kontrolli — vähendame kalki ja pikendame seadme eluiga.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Boileri hooldus ja läbipesu</li>
              <li>Boileri remont ja vahetus</li>
              <li>Küttesüsteemi loputamine</li>
              <li>Soojusvahetite puhastamine</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Услуги торуаби в Мустамяэ</h2>
        <p class="text-gray-700 mb-6">В районе Мустамяэ мы предлагаем все услуги торуаби, включая:</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Торуаби в новостройках Мустамяэ</h3>
            <p class="text-gray-700 mb-3">В Хииу и Вяйке-Ыйсмяэ — новые дома с пластиковыми трассами: установка и ремонт сантехники, унитазов и стиральных подключений без повреждения фасада.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Установка и ремонт сантехники</li>
              <li>Прочистка канализации в новостройках</li>
              <li>Обслуживание бойлеров</li>
              <li>Обслуживание систем отопления</li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Обслуживание бойлеров в Мустамяэ</h3>
            <p class="text-gray-700 mb-3">В Кадака и Сяэсе много домов 1980-х — сезонная промывка бойлера и проверка анода снижают накипь и риск протечек.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Обслуживание и промывка бойлеров</li>
              <li>Ремонт и замена бойлеров</li>
              <li>Промывка систем отопления</li>
              <li>Очистка теплообменников</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Reviews -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi Mustamäel – kliendiarvustused</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Andres L.</span>
            </div>
            <p class="text-gray-700 mb-2">"Väike-Õismäe uues korteris paigaldati WC ja pesumasinavoolikud ühe päevaga — kõik korras ja puhas töö."</p>
            <p class="text-sm text-gray-500">10. detsember 2025</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Kadri M.</span>
            </div>
            <p class="text-gray-700 mb-2">"Kadaka paneelmajas tehti boileri läbipesu enne küttehooaega — soe vesi tuli tagasi ilma leketeta."</p>
            <p class="text-sm text-gray-500">25. november 2025</p>
          </div>
        </div>
        <p class="text-center mt-6 text-gray-600">Keskmine hinnang: <span class="font-bold text-trust-blue">4.9/5</span> (432 arvustust)</p>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Торуаби в Мустамяэ – отзывы клиентов</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Андрес Л.</span>
            </div>
            <p class="text-gray-700 mb-2">"В новостройке на Вяйке-Ыйсмяэ установили унитаз и подключение стиралки за один визит — аккуратно и без грязи."</p>
            <p class="text-sm text-gray-500">10 декабря 2025</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Кадри М.</span>
            </div>
            <p class="text-gray-700 mb-2">"В Кадака промыли бойлер перед отопительным сезоном — горячая вода вернулась без протечек."</p>
            <p class="text-sm text-gray-500">25 ноября 2025</p>
          </div>
        </div>
        <p class="text-center mt-6 text-gray-600">Средняя оценка: <span class="font-bold text-trust-blue">4.9/5</span> (432 отзыва)</p>
      </section>

      <!-- Areas in Mustamäe -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi Mustamäe piirkonnad</h2>
        <p class="text-gray-700 mb-4">Teenindame kõiki Mustamäe piirkondi, sealhulgas:</p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Mustamäe</h3>
            <p class="text-sm text-gray-600">Toruabi Mustamäe piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Sääse</h3>
            <p class="text-sm text-gray-600">Toruabi Sääse piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Kadaka</h3>
            <p class="text-sm text-gray-600">Toruabi Kadaka piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Hiiu</h3>
            <p class="text-sm text-gray-600">Toruabi Hiiu piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Männiku</h3>
            <p class="text-sm text-gray-600">Toruabi Männiku piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Väike-Õismäe</h3>
            <p class="text-sm text-gray-600">Toruabi Väike-Õismäe piirkonnas</p>
          </div>
        </div>
        <div class="bg-trust-blue text-white rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Toruabi ka teistes Tallinna piirkondades</h3>
          <p class="text-gray-200 mb-3">Teenindame ka teisi Tallinna piirkondi:</p>
          <ul class="space-y-2">
            <li><a href="/toruabi-lasnamae" class="text-emergency-red hover:underline font-semibold">Toruabi Lasnamäes</a> – kiire avarii toruabi ja kanalisatsiooni toruabi Lasnamäe piirkonnas</li>
            <li><a href="/toruabi-kesklinn" class="text-emergency-red hover:underline font-semibold">Toruabi Kesklinnas</a> – kiire avarii toruabi Tallinna kesklinna piirkonnas</li>
            <li><a href="/toruabi-pirita" class="text-emergency-red hover:underline font-semibold">Toruabi Piritas</a> – professionaalne avarii toruabi Pirita piirkonnas 24/7</li>
            <li><a href="/toruabi-viimsi" class="text-emergency-red hover:underline font-semibold">Toruabi Viimsis</a> – professionaalne avarii toruabi Viimsi piirkonnas 24/7</li>
          </ul>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Районы обслуживания торуаби в Мустамяэ</h2>
        <p class="text-gray-700 mb-4">Мы обслуживаем все районы Мустамяэ, включая:</p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Мустамяэ</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Мустамяэ</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Сяэсе</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Сяэсе</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Кадака</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Кадака</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Хииу</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Хииу</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Мяннику</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Мяннику</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Вяйке-Ыйсмяэ</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Вяйке-Ыйсмяэ</p>
          </div>
        </div>
        <div class="bg-trust-blue text-white rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Торуаби также в других районах Таллина</h3>
          <p class="text-gray-200 mb-3">Мы также обслуживаем другие районы Таллина:</p>
          <ul class="space-y-2">
            <li><a href="/toruabi-lasnamae" class="text-emergency-red hover:underline font-semibold">Торуаби в Ласнамяэ</a> – быстрая аварийная сантехника и прочистка канализации в районе Ласнамяэ</li>
            <li><a href="/toruabi-kesklinn" class="text-emergency-red hover:underline font-semibold">Торуаби в Кесклинне</a> – быстрая аварийная сантехника в центре Таллина</li>
            <li><a href="/toruabi-pirita" class="text-emergency-red hover:underline font-semibold">Торуаби в Пирита</a> – профессиональная аварийная сантехника в районе Пирита 24/7</li>
            <li><a href="/toruabi-viimsi" class="text-emergency-red hover:underline font-semibold">Торуаби в Виймси</a> – профессиональная аварийная сантехника в районе Виймси 24/7</li>
          </ul>
        </div>
      </section>

