---

import BaseLayout from '../layouts/BaseLayout.astro';
import StickyCTA from '../components/StickyCTA.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import DistrictCrossLinks from '../components/DistrictCrossLinks.astro';
import FooterLegal from '../components/FooterLegal.astro';
import CallStripCta from '../components/CallStripCta.astro';
import DistrictTallinnJsonLd from '../components/seo/DistrictTallinnJsonLd.astro';
import { tallinnDistrictBreadcrumbJsonLd, tallinnDistrictPageUrl } from '../utils/district-tallinn-jsonld';
import { pageLang } from '../utils/page-lang';
import {
  getTallinnDistrict,
  tallinnDistrictDescription,
  tallinnDistrictH1,
  tallinnDistrictIntro,
  tallinnDistrictTitle,
} from '../data/seo-keywords';

const siteUrl = 'https://toruabii.ee';
const districtSeo = getTallinnDistrict('lasnamae');

const phoneNumber = '+372 5633 3332';
const phoneLink = phoneNumber.replace(/\s/g, '');

const currentLang = pageLang(Astro.url);

const titleEt = tallinnDistrictTitle('lasnamae', 'et');
const descEt = tallinnDistrictDescription('lasnamae', 'et');
const titleRu = tallinnDistrictTitle('lasnamae', 'ru');
const descRu = tallinnDistrictDescription('lasnamae', 'ru');

const pageTitle = currentLang === 'ru' ? titleRu : titleEt;
const pageDescription = currentLang === 'ru' ? descRu : descEt;

const districtPath = '/toruabi-lasnamae';
const pageCanonicalUrl = tallinnDistrictPageUrl(districtPath, currentLang);
const breadcrumbJsonLdOverride = tallinnDistrictBreadcrumbJsonLd(districtPath, currentLang, titleEt, titleRu);

const lasnamaeFaqEt = [
  {
    q: 'Kui kiiresti saab toruabi Lasnamäesse?',
    a: 'Lasnamäe piirkonnas jõuame tavaliselt 30-45 minutiga kohale. Avariikõnedele reageerime kohe.',
  },
  {
    q: 'Millised on toruabi hinnad Lasnamäes?',
    a: 'Toruabi hinnad Lasnamäes on samad, mis kogu Tallinnas. Väljasõit on 0€. Vaata täielikku hinnakirja meie veebilehelt.',
  },
  {
    q: 'Kas toruabi töötab Lasnamäes ööpäevaringselt?',
    a: 'Jah, oleme kättesaadavad 24/7 avariikõnedele Lasnamäes. Planeeritud tööde jaoks töötame tavapäraselt kella 8-20 vahel.',
  },
  {
    q: 'Kas teil on kogemus Lasnamäe paneelmajadega?',
    a: 'Jah, meil on pikk kogemus töötamisega Lasnamäe paneelmajades ja KÜ-dega. Tunneme nende hoonete spetsiifikaid ja teame, kuidas kiiresti lahendada probleeme vanades torustikes.',
  },
  {
    q: 'Millised on tüüpilised toruabi probleemid Lasnamäes?',
    a: 'Lasnamäe paneelmajades on tüüpilised probleemid: kanalisatsiooni ummistused vanades torustikes, küttesüsteemi probleemid ja boileri hooldus. Meie toruabi meeskond tunneb nende probleemide lahendamist hästi.',
  },
  {
    q: 'Kas toruabi väljasõit on tasuta Lasnamäes?',
    a: 'Jah, väljasõit on 0€ Lasnamäe piires. Tallinna piires on väljasõit alati tasuta. Väljaspool Tallinna kokkuleppel dispetšeriga.',
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={currentLang}
  canonical={pageCanonicalUrl}
  ogImage="https://toruabii.ee/photos/maintoruabii.webp"
  suppressPlumbingJsonLd
  breadcrumbJsonLdOverride={breadcrumbJsonLdOverride}
>
  <DistrictTallinnJsonLd
    slot="head"
    districtPath={districtPath}
    currentLang={currentLang}
    pageDescription={pageDescription}
    addressLocality="Lasnamäe"
    areaServedName="Lasnamäe"
    plumbingDisplayNameEt="toruabii.ee - Toruabi Lasnamäes"
    plumbingDisplayNameRu="toruabii.ee — торуаби в Ласнамяэ"
    offerCatalogNameEt="Toruabi teenused Lasnamäes"
    offers={[
      {
        nameEt: 'Toruabi Lasnamäes',
        descEt: 'Avarii toruabi ja kanalisatsiooni toruabi Lasnamäe piirkonnas 24/7',
      },
      {
        nameEt: 'Kanalisatsiooni toruabi Lasnamäes',
        descEt: 'Kanalisatsiooni ummistuste likvideerimine ja hooldus Lasnamäe paneelmajades',
      },
      {
        nameEt: 'Boileri toruabi Lasnamäes',
        descEt: 'Boileri hooldus, läbipesu ja remont Lasnamäe piirkonnas',
      },
    ]}
    faqEt={lasnamaeFaqEt}
  />
  <!-- Desktop Navigation -->
  
  <!-- Hero Section -->
  <header class="bg-trust-blue text-white py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <Breadcrumb
        items={[
          { name: currentLang === 'ru' ? 'Главная' : 'Avaleht', url: currentLang === 'ru' ? siteUrl + '/ru' : siteUrl + '/' },
          { name: currentLang === 'ru' ? 'Торуаби по районам' : 'Toruabi piirkondades', url: siteUrl + '/#piirkonnad' },
          { name: currentLang === 'ru' ? 'Торуаби в Ласнамяэ' : 'Toruabi Lasnamäes', url: siteUrl + '/toruabi-lasnamae' }
        ]}
        class="text-gray-300 mb-3"
      />
      {currentLang === 'ru' ? (
        <a href="/ru" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">← На главную</a>
      ) : (
        <a href="/" class="inline-block mb-4 text-emergency-red hover:text-red-400 font-bold">← Tagasi avalehele</a>
      )}
      <h1 class="text-4xl md:text-5xl font-bold mb-3">{currentLang === 'ru' ? tallinnDistrictH1('lasnamae', 'ru') : tallinnDistrictH1('lasnamae', 'et')}</h1>
      <p class="text-xl text-gray-200 mb-6">{currentLang === 'ru' ? tallinnDistrictIntro('lasnamae', 'ru') : tallinnDistrictIntro('lasnamae', 'et')}</p>
      <a href={`tel:${phoneLink}`} class="inline-block bg-emergency-red hover:bg-red-700 text-white font-bold py-4 px-8 rounded-lg text-xl">
        <span data-lang="callNowFull">HELISTA KOHE</span>: {phoneNumber}
      </a>
    </div>
  </header>

  <main class="py-12 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto space-y-12">

      <CallStripCta variant="page" />
      
      <!-- Why Choose Toruabi Lasnamäes -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Miks valida toruabi Lasnamäes?</h2>
        <h3 class="text-lg font-semibold text-trust-blue mb-3">Peamised põhjused</h3>
        <p class="text-gray-700 mb-4">Lasnamäe on Eesti suurim paneelmaja piirkond, kus ummistused ja kütteprobleemid korduvad sarnastes trepikodades. Meil on kogemus KÜ-de, ühisköökide ja vanade horisontaaltrassidega — diagnoos ja töö tehakse sageli 30–45 minutiga pärast väljakutset.</p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Kohalik ekspert:</strong> Meie meistrid töötavad Lasnamäes regulaarselt ja tunnevad piirkonna spetsiifikaid</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Kiire reageerimine:</strong> Lasnamäe piirkonnas jõuame kohale tavaliselt 30-45 minutiga</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Paneelmajade kogemus:</strong> Meil on pikk kogemus töötamisega Lasnamäe paneelmajades ja KÜ-dega</li>
        </ul>
        
        <div class="bg-trust-blue text-white rounded-lg p-6 mt-6">
          <h3 class="text-2xl font-bold mb-4">Toruabi Lasnamäes – meie statistikat</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-bold mb-2">547+</div>
              <p class="text-gray-200">Rahulolu klienti Lasnamäes</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">35 min</div>
              <p class="text-gray-200">Keskmine reageerimisaeg</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">10+</div>
              <p class="text-gray-200">Aastat kogemust Lasnamäes</p>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Почему выбирают торуаби в Ласнамяэ?</h2>
        <h3 class="text-lg font-semibold text-trust-blue mb-3">Основные причины</h3>
        <p class="text-gray-700 mb-4">Ласнамяэ — крупнейший район с панельными домами 1970–1980-х: повторяющиеся засоры в горизонтальных трассах и проблемы отопления. Мы знаем практику КУ и типовые планировки — диагностика и выезд обычно за 30–45 минут.</p>
        <ul class="space-y-3 text-gray-700 mb-6">
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Местный эксперт:</strong> Наши мастера регулярно работают в Ласнамяэ и знают специфику района</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Быстрое реагирование:</strong> В районе Ласнамяэ мы обычно приезжаем за 30-45 минут</li>
          <li class="flex items-start"><span class="text-emergency-red mr-2">✓</span> <strong>Опыт работы в панельных домах:</strong> У нас большой опыт работы в панельных домах Ласнамяэ и с КУ</li>
        </ul>
        
        <div class="bg-trust-blue text-white rounded-lg p-6 mt-6">
          <h3 class="text-2xl font-bold mb-4">Торуаби в Ласнамяэ – наша статистика</h3>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-bold mb-2">547+</div>
              <p class="text-gray-200">Довольных клиентов в Ласнамяэ</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">35 мин</div>
              <p class="text-gray-200">Среднее время реагирования</p>
            </div>
            <div>
              <div class="text-3xl font-bold mb-2">10+</div>
              <p class="text-gray-200">Лет опыта в Ласнамяэ</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Services in Lasnamäe -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi teenused Lasnamäes</h2>
        <p class="text-gray-700 mb-6">Lasnamäe piirkonnas pakume kõiki toruabi teenuseid, sealhulgas:</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Toruabi Lasnamäe paneelmajades</h3>
            <p class="text-gray-700 mb-3">Lasnamäe paneelmajades pakume kanalisatsiooni toruabi, küttehooldust ja boileri teenuseid. Tunneme KÜ-de praktikat ja vanu horisontaaltrasse — diagnoos tehakse enne tööd, mitte pärast lammutamist.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Kanalisatsiooni toruabi ja ummistuste likvideerimine</li>
              <li>Küttesüsteemi toruabi ja hooldus</li>
              <li>Boileri toruabi ja läbipesu</li>
              <li>Torustike remont ja renoveerimine</li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Kanalisatsiooni toruabi Lasnamäe vanades majades</h3>
            <p class="text-gray-700 mb-3">1970.–1980. aastate majades teeme survepesu ja videouuringut, et leida ummistuse põhjus ilma liigse lammutuseta. Vajadusel planeerime trassi renoveerimise samm-sammult.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Survepesu kanalisatsioonisüsteemidest</li>
              <li>Videouuring torustiku seisukorra kontrollimiseks</li>
              <li>Rasvapüüduri puhastamine</li>
              <li>Kanalisatsioonitrasside renoveerimine</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Услуги торуаби в Ласнамяэ</h2>
        <p class="text-gray-700 mb-6">В районе Ласнамяэ мы предлагаем все услуги торуаби, включая:</p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Торуаби в панельных домах Ласнамяэ</h3>
            <p class="text-gray-700 mb-3">Ласнамяэ известен своими панельными домами. Наша команда знает специфику этих зданий и умеет быстро решать проблемы в старых коммуникациях.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Прочистка канализации и устранение засоров</li>
              <li>Обслуживание систем отопления</li>
              <li>Обслуживание и промывка бойлеров</li>
              <li>Ремонт и реконструкция трубопроводов</li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-trust-blue mb-3">Прочистка канализации в старых домах Ласнамяэ</h3>
            <p class="text-gray-700 mb-3">Многие дома в Ласнамяэ построены в 1970-1980-х годах, и их канализационные системы требуют регулярного обслуживания. Наша команда использует профессиональное оборудование для устранения засоров.</p>
            <ul class="list-disc list-inside text-gray-700 space-y-1">
              <li>Гидродинамическая промывка канализационных систем</li>
              <li>Видеообследование для проверки состояния трубопроводов</li>
              <li>Очистка жироуловителей</li>
              <li>Реконструкция канализационных трасс</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Reviews -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi Lasnamäes – kliendiarvustused</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Mari K.</span>
            </div>
            <p class="text-gray-700 mb-2">"Väga kiire ja professionaalne toruabi Lasnamäes! Kanalisatsiooni ummistus lahendati kiiresti ja kvaliteetselt. Soovitan!"</p>
            <p class="text-sm text-gray-500">15. detsember 2025</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Jaan T.</span>
            </div>
            <p class="text-gray-700 mb-2">"Boileri hooldus Lasnamäes tehti väga hästi. Meister oli professionaalne ja selgitas kõik selgelt. Garantii 2 aastat annab rahu."</p>
            <p class="text-sm text-gray-500">20. november 2025</p>
          </div>
        </div>
        <p class="text-center mt-6 text-gray-600">Keskmine hinnang: <span class="font-bold text-trust-blue">4.9/5</span> (547 arvustust)</p>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Торуаби в Ласнамяэ – отзывы клиентов</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Мари К.</span>
            </div>
            <p class="text-gray-700 mb-2">"Очень быстрая и профессиональная торуаби в Ласнамяэ! Засор канализации решили быстро и качественно. Рекомендую!"</p>
            <p class="text-sm text-gray-500">15 декабря 2025</p>
          </div>
          <div class="bg-gray-50 rounded-lg p-6">
            <div class="flex items-center mb-3">
              <div class="text-yellow-400 text-xl">★★★★★</div>
              <span class="ml-2 font-bold text-trust-blue">Яан Т.</span>
            </div>
            <p class="text-gray-700 mb-2">"Обслуживание бойлера в Ласнамяэ сделали очень хорошо. Мастер был профессионален и всё объяснил. Гарантия 2 года даёт спокойствие."</p>
            <p class="text-sm text-gray-500">20 ноября 2025</p>
          </div>
        </div>
        <p class="text-center mt-6 text-gray-600">Средняя оценка: <span class="font-bold text-trust-blue">4.9/5</span> (547 отзывов)</p>
      </section>

      <!-- Areas in Lasnamäe -->
      <section class="bg-white rounded-lg shadow-lg p-8 blog-et">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Toruabi Lasnamäe piirkonnad</h2>
        <p class="text-gray-700 mb-4">Teenindame kõiki Lasnamäe piirkondi, sealhulgas:</p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Priisle</h3>
            <p class="text-sm text-gray-600">Toruabi Priisle piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Ülemiste</h3>
            <p class="text-sm text-gray-600">Toruabi Ülemiste piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Laagna</h3>
            <p class="text-sm text-gray-600">Toruabi Laagna piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Tondiraba</h3>
            <p class="text-sm text-gray-600">Toruabi Tondiraba piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Kuristiku</h3>
            <p class="text-sm text-gray-600">Toruabi Kuristiku piirkonnas</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Sikupilli</h3>
            <p class="text-sm text-gray-600">Toruabi Sikupilli piirkonnas</p>
          </div>
        </div>
        <div class="bg-trust-blue text-white rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Toruabi ka teistes Tallinna piirkondades</h3>
          <p class="text-gray-200 mb-3">Teenindame ka teisi Tallinna piirkondi:</p>
          <ul class="space-y-2">
            <li><a href="/toruabi-mustamae" class="text-emergency-red hover:underline font-semibold">toruabi mustamäe</a></li>
            <li><a href="/toruabi-kesklinn" class="text-emergency-red hover:underline font-semibold">toruabi kesklinn</a></li>
            <li><a href="/toruabi-pirita" class="text-emergency-red hover:underline font-semibold">toruabi pirita</a></li>
          </ul>
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-lg p-8 blog-ru">
        <h2 class="text-3xl font-bold text-trust-blue mb-6">Районы обслуживания торуаби в Ласнамяэ</h2>
        <p class="text-gray-700 mb-4">Мы обслуживаем все районы Ласнамяэ, включая:</p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Прийсле</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Прийсле</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Юлемисте</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Юлемисте</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Лаагна</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Лаагна</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Тондираба</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Тондираба</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Куристику</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Куристику</p>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg">
            <h3 class="font-bold text-trust-blue mb-2">Сикупилли</h3>
            <p class="text-sm text-gray-600">Торуаби в районе Сикупилли</p>
          </div>
        </div>
        <div class="bg-trust-blue text-white rounded-lg p-6">
          <h3 class="text-xl font-bold mb-3">Торуаби также в других районах Таллина</h3>
          <p class="text-gray-200 mb-3">Мы также обслуживаем другие районы Таллина:</p>
          <ul class="space-y-2">
            <li><a href="/ru/toruabi-mustamae" class="text-emergency-red hover:underline font-semibold">торуаби мустамяэ</a></li>
            <li><a href="/ru/toruabi-kesklinn" class="text-emergency-red hover:underline font-semibold">торуаби кесклинн</a></li>
            <li><a href="/ru/toruabi-pirita" class="text-emergency-red hover:underline font-semibold">торуаби пирита</a></li>
