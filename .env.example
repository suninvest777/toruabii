# Telegram notifications (server-only — set in Cloudflare Worker env / local .env, never commit secrets)
# Token from @BotFather; chat id from @userinfobot or getUpdates after you message the bot (see TELEGRAM-SETUP.md)
TELEGRAM_BOT_TOKEN=123456789:AAExampleReplaceWithBotFatherToken
TELEGRAM_CHAT_ID=1234567890

# Analytics (optional — omit in dev; set in Cloudflare Pages env for production)
# Create a NEW GA4 property for toruabii.ee only (do not reuse 24toruabi IDs)
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# Ahrefs Analytics site key from Ahrefs → Analytics → Add site
PUBLIC_AHREFS_ANALYTICS_KEY=YOUR_AHREFS_KEY
